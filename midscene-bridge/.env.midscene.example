# =============================================================================
# Midscene Bridge 自己的环境变量
# 本文件 NOT 由 ai-phone 主仓加载；bridge 子进程启动时单独 dotenv 读 .env.midscene
# 升级 ai-phone vlm 模型时记得手工把模型/key 同步到这里
# =============================================================================

# --- Midscene 用的 VLM ---
# 与 ai-phone 主链路同款（doubao-seed-1-6-vision-250815）走 OpenAI 兼容协议
# 火山方舟 Ark 端点 / API key
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=<填你的 doubao key, 与 ai-phone 后端 AI_PHONE_VLM_API_KEY 同值>
MIDSCENE_MODEL_NAME=doubao-seed-1-6-vision-250815

# --- Midscene 视觉模式开关 ---
# ⚠️ 关键陷阱：Midscene 判定逻辑是"变量存在即启用"，**不看值**！
#   写 MIDSCENE_USE_XXX=0 不是关闭，是"启用"——会触发"多模式同时开"报错
#   不用的视觉模式必须**整行删除/注释**，不能写 =0
#
# 当前用豆包 seed-1.6-vision，必须显式开 DOUBAO_VISION：
#   - 否则 Midscene 按 OpenAI vision 协议解析 bbox
#   - 但豆包 bbox 是 0-1000 归一化坐标，与 OpenAI 格式不同 → 定位全错
MIDSCENE_USE_DOUBAO_VISION=1
# 其它视觉模式保持注释（解开就会被识别为启用）：
# MIDSCENE_USE_QWEN_VL
# MIDSCENE_USE_QWEN3_VL
# MIDSCENE_USE_VLM_UI_TARS
# MIDSCENE_USE_GEMINI

# 调试日志：1=打 ai-profile / 0=不打。建议初次跑通后关闭省 stdout
MIDSCENE_DEBUG_AI_PROFILE=1
MIDSCENE_DEBUG_AI_RESPONSE=0

# --- Android 工具链（必填）---
# brew install --cask android-platform-tools 后，ANDROID_HOME 默认 /Users/$USER/Library/Android/sdk
ANDROID_HOME=/Users/<you>/Library/Android/sdk
# adb 二进制可执行文件路径，留空走 PATH
# ADB_PATH=

# --- 其它 ---
# Midscene 报告输出根目录；ai-phone 主仓 spawn 时会通过命令行 --report-dir 覆盖此值
# MIDSCENE_RUN_DIR=./midscene_run
