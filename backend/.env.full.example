# ============================================================================
# ai-phone backend/.env.full.example
#
# 这是全量高级参数参考，不参与运行时加载。
# 日常部署请复制 .env.example 到 .env；默认策略请看 .env.defaults。
# 本文件只用于查找高级开关、阈值、调参项的含义。
# ============================================================================


# ─────────────────── 1. 运行环境 ───────────────────

# 运行环境标识。仅用于日志区分，可留 local。可选值：local / dev / prod。
AI_PHONE_ENV=local

# 日志级别。DEBUG=最详细（排障用）/ INFO=日常 / WARNING=只看异常。
AI_PHONE_LOG_LEVEL=INFO


# ─────────────────── 2. 数据库 ★ ───────────────────

# Postgres 连接串。两种典型选择：
#   A. 共用远程 PG（找另一台 Mac 拷连接串）：
#      postgresql+asyncpg://<user>:<password>@<host>:5432/auto_app
#   B. 本机起 PG：
#      brew install postgresql@15 && brew services start postgresql@15 && createdb auto_app
#      连接串改为：postgresql+asyncpg://<本机用户>@127.0.0.1:5432/auto_app
# 注意：选 A 时同时只一台 Mac 跑 agent，否则 run id 撞车。
AI_PHONE_DB_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/auto_app

# 本地存储目录（截图、HTML 报告、调试 dump）。相对路径，相对 backend/ 工作目录。
AI_PHONE_STORAGE_DIR=./.data/storage


# ─────────────────── 3. Server（uvicorn 监听）───────────────────

# Server 监听地址；0.0.0.0=对外开放（局域网/同事远程能连）；127.0.0.1=只本机
AI_PHONE_SERVER_HOST=0.0.0.0

# Server HTTP/WS 端口
AI_PHONE_SERVER_PORT=8000

# 前端域名白名单（CORS 允许列表，**JSON 数组格式**；含 dev / 生产域名）
# 改前端部署域名时一定要同步改这里，否则浏览器报跨域
# 例：AI_PHONE_CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
AI_PHONE_CORS_ORIGINS=["http://127.0.0.1:5180","http://localhost:5180"]


# ─────────────────── 4. Agent ↔ Server 鉴权 ───────────────────

# Agent 连 Server 的 WebSocket 地址。本机 server 改成 127.0.0.1 即可。
# 终端启动也可以直接传普通 Server 地址：
#   python -m ai_phone agent --server http://<server-host>:8000 --token <token>
# 代码会自动推导 ws://<server-host>:8000/ws/agent 与 HTTP base。
AI_PHONE_SERVER_WS_URL=ws://127.0.0.1:8000/ws/agent

# Agent 调 Server REST API 的 base URL（截图回传、报告上传等）。
# 如果命令行传了 --server，本值会按 --server 自动推导。
AI_PHONE_SERVER_HTTP_BASE=http://127.0.0.1:8000

# Agent ↔ Server 共享 token；本地开发 dev 即可。
# 生产建议改长随机串，并保证 server 端同步更新。
AI_PHONE_AGENT_TOKEN=dev

# Agent 注册名（前端设备卡片显示在 "Agent" 字段）。留空自动用主机名。
# AI_PHONE_AGENT_NAME=mac-local

# 内部 submissions 接口 Bearer token（Web 队列总览页 / 内部投递走这把）。
# 留空则 fall back 到 AI_PHONE_AGENT_TOKEN；多人协作时建议独立设值。
# 前端通过 VITE_AI_PHONE_SUBMISSION_TOKEN 读到后带到 Authorization 头
# AI_PHONE_SUBMISSION_INTERNAL_TOKEN=


# ═══════════════════ 5. 模型配置（新版两块）★★★ ═══════════════════
#
# 本系统是“长循环 Agent 执行系统”：截图 → 模型决策 → 执行动作 → 再截图 → …
# → 直到 finished。对外只配两块连接身份，系统内部按 provider 拆成主循环和单次辅助。
#
# provider 支持：
#   · doubao：主循环走方舟 Responses；手机层单次辅助走方舟 Chat。
#   · claude：主循环走已验证的 Claude Computer Use；手机层单次辅助走 Claude Messages。
#   · openai/gpt：主循环走 OpenAI Computer Use；手机层单次辅助走 OpenAI Responses。
#
# ⚠️【doubao 必做·手动步骤】登录火山方舟控制台，为所用模型/接入点**手动开启
#    “上下文缓存（主动缓存）”开关**。这一步是手动的，不开则主动缓存完全不生效，
#    长任务会非常贵！
#    控制台：https://console.volcengine.com/ark
#
# 你只需配下面两块（连接身份），系统内部自动拆协议，无需手填旧式 VLM_* endpoint：
#   · 碰手机 VLM（PHONE_VLM）：主决策 + 缓存回放的辅助恢复/定位/门控，vision 专版。
#       doubao 主决策 → {BASE_URL}/responses；单次辅助 → {BASE_URL}/chat/completions
#       claude 主决策/单次辅助 → /v1/messages，不同调用层自动分开
#       openai 主决策/单次辅助 → /v1/responses，不同调用层自动分开
#   · 辅助模型（AUX）：包名/通道/审判/断言/瞬态分类/大盘分析，通用版，单次。
#       按 AUX_PROVIDER 自动选择 doubao_chat / claude / openai。
#
# 生效规则：PHONE_VLM 和 AUX 各自的 PROVIDER + BASE_URL + API_KEY + MODEL 四项都必填。
# 系统会自动派生并接管底层所有模型连接；缺项直接报配置错误，不再回退旧式 VLM_*。
#
# 分发规则：
#   · Server .env 填这里；Agent 本机通常不需要填模型 ENV。
#   · PHONE_VLM 四项会随 Agent 配置包下发并覆盖，缺任一项则 VLM Run 不执行。
#   · AUX 四项也会随 Agent 配置包下发并覆盖，缺任一项则配置失败。
#   · AUX 不能留空跟随 PHONE_VLM；海外主模型带 Computer Use 执行语义，不适合兜底做通用辅助判断。
#   · 连接 Server、WDA 签名/路径、本机存储等物理本机字段不下发，仍由 Agent 本机 .env 控制。
#
# 填写步骤：
#   1. 先选一个 PHONE_VLM_PROVIDER：doubao / claude / openai。
#   2. 只改下面 PHONE_VLM 四行：PROVIDER / MODEL / API_KEY / BASE_URL。
#   3. 再填写 AUX 四行：PROVIDER / MODEL / API_KEY / BASE_URL；即使和 PHONE_VLM 用同一个 key，也要显式写。
#   4. 不要再填写 AI_PHONE_VLM_BACKEND / AI_PHONE_VLM_API_KEY / AI_PHONE_ASSISTANT_*，
#      这些旧式连接字段已经由系统内部自动派生。
#
# 三套可复制取值（把下面实际 8 行改成对应值即可，不要在 .env 里重复写多套同名变量）：
#
# A. 豆包 / 火山方舟（国内默认）
#   AI_PHONE_PHONE_VLM_PROVIDER=doubao
#   AI_PHONE_PHONE_VLM_MODEL=doubao-seed-1-6-vision-250815
#   AI_PHONE_PHONE_VLM_API_KEY=<你的火山方舟 API Key>
#   AI_PHONE_PHONE_VLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#   AI_PHONE_AUX_PROVIDER=doubao
#   AI_PHONE_AUX_MODEL=doubao-seed-1-6-250615
#   AI_PHONE_AUX_API_KEY=<你的火山方舟 API Key>
#   AI_PHONE_AUX_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#
# B. Claude（保持已验证的 Claude Computer Use 执行链路）
#   AI_PHONE_PHONE_VLM_PROVIDER=claude
#   AI_PHONE_PHONE_VLM_MODEL=claude-sonnet-4-5
#   AI_PHONE_PHONE_VLM_API_KEY=<你的 Anthropic API Key>
#   AI_PHONE_PHONE_VLM_BASE_URL=https://api.anthropic.com
#   AI_PHONE_AUX_PROVIDER=claude
#   AI_PHONE_AUX_MODEL=claude-haiku
#   AI_PHONE_AUX_API_KEY=<你的 Anthropic API Key>
#   AI_PHONE_AUX_BASE_URL=https://api.anthropic.com
#
# C. OpenAI / GPT（主循环走 GPT Computer Use）
#   AI_PHONE_PHONE_VLM_PROVIDER=openai
#   AI_PHONE_PHONE_VLM_MODEL=computer-use-preview
#   AI_PHONE_PHONE_VLM_API_KEY=<你的 OpenAI API Key>
#   AI_PHONE_PHONE_VLM_BASE_URL=https://api.openai.com/v1
#   AI_PHONE_AUX_PROVIDER=openai
#   AI_PHONE_AUX_MODEL=gpt-4o-mini
#   AI_PHONE_AUX_API_KEY=<你的 OpenAI API Key>
#   AI_PHONE_AUX_BASE_URL=https://api.openai.com/v1

# ── 碰手机 VLM（vision 专版，主决策 + 辅助恢复）──
# PROVIDER 可选 doubao / claude / openai（gpt）。
AI_PHONE_PHONE_VLM_PROVIDER=doubao
# 模型示例：doubao-seed-1-6-vision-* / claude-sonnet-* / computer-use-preview。
AI_PHONE_PHONE_VLM_MODEL=doubao-seed-1-6-vision-250815
# **必填**。对应 provider 的 API Key。
AI_PHONE_PHONE_VLM_API_KEY=
# doubao 填到 /api/v3；claude 可填 https://api.anthropic.com/v1/messages；
# openai 可填 https://api.openai.com/v1 或 https://api.openai.com/v1/responses。
AI_PHONE_PHONE_VLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 辅助模型（通用版，不碰手机的判断/裁决）──
# **必填**。PROVIDER 可选 doubao / claude / openai，不能留空跟随 PHONE_VLM。
AI_PHONE_AUX_PROVIDER=doubao
# **必填**。通用版即可；只做文本/看图判断，不操作手机。
AI_PHONE_AUX_MODEL=doubao-seed-1-6-250615
# **必填**。即使和 PHONE_VLM 用同一个 key，也要显式写。
AI_PHONE_AUX_API_KEY=
# **必填**。doubao 填到 /api/v3；claude 可填 https://api.anthropic.com；
# openai 可填 https://api.openai.com/v1。
AI_PHONE_AUX_BASE_URL=https://ark.cn-beijing.volces.com/api/v3


# ─────────────────── 6. 模型行为参数（与连接无关）───────────────────

# 会话分段阈值：上一轮 prompt_tokens ≥ 该值时下轮自动重置 previous_response_id。
# 方舟视觉 ≤32K 一档、>32K 二档 ×2 计费，30000 留 2K buffer。<=0 关闭分段。
AI_PHONE_VLM_SESSION_RESET_PROMPT_THRESHOLD=30000

# Claude/GPT Computer Use 主 VLM 的中文可读日志 prompt 开关（true / false）。
# 默认关闭：保持海外/开源默认英文 prompt；中文调试时可打开。
AI_PHONE_VLM_CU_ZH_PROMPT_ENABLED=false

# Claude 主 VLM 思考链预算（tokens）。仅 PHONE_VLM_PROVIDER=claude 生效，0=关闭 thinking。
# 1024 是 Claude Computer Use 的轻量起点；复杂任务可调高。
AI_PHONE_VLM_MAIN_THINKING_BUDGET=1024

# Claude / GPT 主 VLM 客户端历史滑窗保留的最近步数。
# 长任务 30 步以上时只保留首屏 1 步 + 最近 N 步对，避免 token 爆。
AI_PHONE_VLM_HISTORY_WINDOW_STEPS=12

# GPT 主 VLM 推理强度。仅 PHONE_VLM_PROVIDER=openai/gpt 生效，可选 low / medium / high。
# computer-use-preview 必须有非零 effort；常规自动化保持 medium。
AI_PHONE_VLM_MAIN_REASONING_EFFORT=medium

# Anthropic prompt caching 开关。仅 PHONE_VLM_PROVIDER=claude 生效。
# 长 case（≥20 步）+ Run 间隔短（<5 分钟）时可省 input token；短 case / 调试建议关闭。
AI_PHONE_VLM_MAIN_PROMPT_CACHING_ENABLED=false

# 审判系统是否开混合推理（thinking）。开启后单次 ~1s → ~5-15s，但裁决更准。
# 审判 / 断言每个 Run 只跑 1-2 次，多花几秒换准确性划算。
AI_PHONE_ASSISTANT_THINKING_JUDGE=true

# 断言系统同上（多约束验证类任务，开思考更稳）。
AI_PHONE_ASSISTANT_THINKING_ASSERTION=true


# ─────────────────── 7. 瞬态 UI 检测（视频工具栏 / Toast / 半透明菜单） ───────────────────

# 总开关；开启后还需 goal 命中关键词白名单才真正启用，避免普通用例多花算力
AI_PHONE_TRANSIENT_UI_ENABLED=true

# 命中即启用瞬态 UI 检测的关键词白名单（CSV，大小写无关、忽略空格）
AI_PHONE_TRANSIENT_UI_KEYWORDS=视频,播放,倍速,直播,video,player,play,toast

# detector 抓 late 帧前的等待时间（毫秒）。需 > 工具栏典型寿命，否则 late 帧时
# 工具栏还在，三段判定的"消失率"达不到阈值。6000ms 是洋葱学园 ~5s 寿命场景的甜点
# （实测峰值比 8.71）；适配寿命更长的工具栏（8s/10s）调高即可。
AI_PHONE_TRANSIENT_UI_LATE_DELAY_MS=6000


# ─────────────────── 8. Android 电源策略 + 镜像（scrcpy → ffmpeg → MSE） ───────────────────
#
# 推荐部署默认：空闲时允许手机自然息屏，任务真正开始前再唤醒。
# 这样比“插线后长期常亮”更省电、少发热，也减少长时间亮屏导致的系统弹窗/烧屏风险。
# 前提：无人值守设备应人工关闭 PIN / 图案 / 密码等安全锁；系统安全锁不能被自动绕过。

# Android 插入/扫描时是否沿用旧的“长期常亮”策略。
# 作用层级：设备发现 / driver 打开阶段；不负责 Run 前唤醒。
#   true  = 历史行为：driver 打开时设置超长 screen_off_timeout + svc power stayon true。
#           适合调试期一直看着屏幕，但长时间插线更容易发热。
#   false = 不改长亮设置，允许设备按系统设置自然息屏。
#           适合“空闲黑屏省电，Run 前再唤醒”的部署方式。
# 本模板默认 false：采用“空闲息屏 + Run 前唤醒”线路。
AI_PHONE_ANDROID_SETUP_STAY_AWAKE=false

# Android 黑屏/DOZE 时 readiness 是否仍允许派发。
# 作用层级：调度准入 / 设备总览状态；决定黑屏设备能不能被自动任务选中。
#   false = 历史行为：黑屏显示 screen_locked，不派发。
#   true  = 把“息屏但可自动唤醒”视为待机态，允许派发。
# 前提条件：设备应人工关闭 PIN / 图案 / 密码等安全锁。系统安全认证不能被自动绕过。
# 本模板默认 true：黑屏待机设备仍可被调度，后续由 Run 前 wake 拉起来。
AI_PHONE_ANDROID_SCREEN_OFF_DISPATCHABLE=true

# Android VLM Run 开始前是否主动亮屏：
# 作用层级：首跑 / V1 / V2 / V3 缓存回放真正执行前。
#   false = 历史行为：不额外唤醒。
#   true  = Run 首张截图前发送 KEYCODE_WAKEUP，并尝试 dismiss 无安全认证 keyguard。
# 这一步只点亮和收起“无安全认证”的 keyguard，不会绕过 PIN/图案/密码。
# 本模板默认 true：配合 SCREEN_OFF_DISPATCHABLE=true，避免首帧黑屏。
AI_PHONE_ANDROID_WAKE_BEFORE_RUN=true

# Android Run 前唤醒后等待屏幕点亮/首帧刷新的时间，单位毫秒。
# 仅 ANDROID_WAKE_BEFORE_RUN=true 时生效。
# 调参建议：
#   - 500：默认，当前常见机型足够。
#   - 800~1000：如果 wake 后首张截图仍黑，或系统点亮动画较慢，可调高。
#   - 0：最快，但更容易遇到首帧没刷出来。
AI_PHONE_ANDROID_WAKE_BEFORE_RUN_SETTLE_MS=500

# Android 进入工作台/启动镜像前是否主动唤醒。
# 作用层级：手动进入工作台、启动/复用镜像、手动 input 前。
#   false = 历史行为；多数 Android 手点黑屏画面会自然点亮。
#   true  = 启动镜像 / 手动 input 前也先 KEYCODE_WAKEUP + dismiss-keyguard。
# 这里只 wake，不自动上滑；手动调试时用户可自己上滑。
# 何时打开：如果某台 Android 和 HarmonyOS 一样“进入工作台仍黑屏、手点也不亮”，再打开。
AI_PHONE_ANDROID_WAKE_ON_ENTER=false

# 所有平台的 Run 收尾电源策略（Server 自动下发给全部 Agent）。
# true  = 最终证据生成后、run_done 上报前主动熄屏：Android KEYCODE_SLEEP；
#         iOS WDA lock（会锁屏）；HarmonyOS power-shell suspend。
# false = 保持任务完成后的当前屏幕状态，交给设备自身自动息屏。
# 不区分真机/虚拟机，且不会改 screen_off_timeout 或 stay-on 系统设置。
AI_PHONE_SLEEP_AFTER_RUN=true

# Mirror 画质 / 流量参数（agent 重启生效）
# MSE 直传方案：scrcpy → ffmpeg(-c:v copy) → 浏览器 <video>，无 JPEG 二次编码
# 三档预设：
#   省流  : MAX_WIDTH=720  BITRATE=2000000   FPS=20
#   清晰  : MAX_WIDTH=1280 BITRATE=6000000   FPS=30  ← 默认
#   锐利  : MAX_WIDTH=1920 BITRATE=12000000  FPS=30
AI_PHONE_MIRROR_MAX_WIDTH=1280
AI_PHONE_MIRROR_MAX_FPS=30
AI_PHONE_MIRROR_BITRATE=6000000

# Mirror 延迟参数（agent 重启生效，前端默认 liveSync=0.4s）
# 端到端延迟 ≈ FRAG_MS + 网络抖动 + liveSyncSeconds(前端)
#   极致低延迟：FRAG_MS=33  GOP_SEC=0    （CPU 略高，WS 帧率高）
#   平衡 (默认)：FRAG_MS=50  GOP_SEC=1
#   省 CPU/带宽：FRAG_MS=200 GOP_SEC=2
AI_PHONE_MIRROR_FRAG_MS=50
AI_PHONE_MIRROR_GOP_SEC=1


# ─────────────────── 9. iOS WDA 工程位置 + 签名信息 ★（仅 iOS 用户）───────────────────

# WebDriverAgent.xcodeproj 所在目录（**绝对路径**）。
# 项目已 vendored 在 ai-phone/third_party/WebDriverAgent，
# 改成本机 clone 仓库后的实际位置即可，例：
#   /Users/<本机用户>/code/ai-phone/third_party/WebDriverAgent
# 留空 → agent 不自动 xcodebuild test，需要你手动 Xcode Cmd+U + iproxy 起 WDA。
AI_PHONE_WDA_PROJECT_DIR=

# WDA 的 Product Bundle Identifier（xcodebuild 命令行覆盖 .pbxproj 用）。
# 两台 Mac 用不同 Apple ID 时各写各的，避免免费 Apple ID 同 Bundle Id 撞 10 个/年配额。
# 建议起 com.<本机用户名>.wda 这种唯一值。留空则用 .pbxproj 里的默认值。
AI_PHONE_WDA_BUNDLE_ID=

# Apple Developer Team ID（10 字符大写），xcodebuild 命令行覆盖 .pbxproj 里的 DEVELOPMENT_TEAM。
# 在 https://developer.apple.com/account 能查到自己的 Team ID。
# 两台 Mac 用不同 Apple ID 时各写各的。留空则用 .pbxproj 里的默认值。
AI_PHONE_WDA_TEAM_ID=


# ─────────────────── 10. iOS 镜像后端切换 ───────────────────

# iOS 镜像后端（三选一）：
#   mjpeg_passthrough（默认、推荐）：WDA mjpeg → JPEG 直通浏览器 <img>，
#                                    每帧独立，旋转/分辨率天然自适应，延迟最低
#   wda_mjpeg                    ：WDA mjpeg → ffmpeg/H.264 → MSE，
#                                    设备旋转时要重建链路；只在 passthrough 出问题时回退
#   dvt_screenshot               ：pmd3 DVT 轮询 PNG，慢、发烫，无 WDA 时保底
AI_PHONE_IOS_MIRROR_BACKEND=mjpeg_passthrough

# WDA 内部缩放到这个最长边像素（mjpeg_passthrough / wda_mjpeg 都生效；0=不缩放）
AI_PHONE_WDA_MJPEG_LONG_EDGE=1280

# JPEG 质量 10-100。passthrough 路径建议 70-80，更清晰；wda_mjpeg 路径 60 即可
AI_PHONE_WDA_MJPEG_QUALITY=80

# 目标帧率（10-30 合理）
AI_PHONE_WDA_MJPEG_FPS=20


# ─────────────────── 11. iOS WDA 生命周期 ───────────────────
#
# 推荐部署默认：stable 稳定线路优先。人工完成一次解锁、信任电脑、开发者模式、
# 开发者 App 信任后，agent 尽量 attach/reuse 现有 WDA；后台扫描不主动扰动
# WDA/XCTest/信任链路。WDA 真失效时显式报错，等待人工拔插/重做准备。

# 即插即用模式：插上 iPhone 就立刻启 WDA，而不是等浏览器点"进入工作台"才启。
# 注意：stable 模式下会跳过 preload；本模板仍显式设 false，避免外部误解为插线预热。
#   false = 按需启动，省电 / 多机不争 CPU，但首次进工作台等 1~3 分钟冷编
#   true  = 插线就启，"Mac 一直烧点 CPU" 换 "点开就能用"，自动化 7x24 推荐
AI_PHONE_IOS_WDA_PRELOAD=true

# WDA 就绪后尝试点亮屏幕（防息屏；只亮屏，不绕锁屏密码）。
# 这不是 Run 前核心开关；Run 前唤醒由 AI_PHONE_IOS_WAKE_BEFORE_RUN 控制。
AI_PHONE_IOS_WAKE_ON_ENTER=true

# iOS /wda/locked=true 时 readiness 是否仍允许派发。
#   false = 历史行为：锁屏/息屏显示 screen_locked，不派发。
#   true  = 允许派发，由 Run 前 wda.unlock 负责点亮/解到桌面。
AI_PHONE_IOS_SCREEN_OFF_DISPATCHABLE=true

# iOS VLM Run 开始前是否主动调用 wda.unlock。
# 只调用 unlock，不叠 press_home，不按设备区分。
AI_PHONE_IOS_WAKE_BEFORE_RUN=true

# iOS Run 前 unlock 后等待屏幕刷新时间，单位毫秒。
AI_PHONE_IOS_WAKE_BEFORE_RUN_SETTLE_MS=500

# iOS WDA 生命周期策略：详见 docs/ios-setup（iOS接入指南）.md
# 与 docs/recommended-env（推荐部署Env清单）.md。
#   auto   = 调试期。允许插线预热 / preflight_deadlock / runtime_drop
#            自动 respawn / /status 不通时关 driver 重建。频繁热拔插 + 本机调试用。
#   stable = 推荐部署默认。人工准备一次后 agent 只 attach/reuse，不主动重启 WDA；
#            失效后抛 StableWdaUnavailable，等人工拔插重做准备。
# 注意：仅影响 iOS WDA 生命周期，不影响 Android / HarmonyOS，也不影响
# iOS 已有 tap / swipe / type / screenshot / mirror action。
AI_PHONE_IOS_WDA_LIFECYCLE_MODE=stable

# stable 模式下是否允许「每次 USB 插入会话内首次自动 spawn WDA」（§7.5.1）：
#   true  = 默认。每次 USB 物理插入后允许 agent 帮忙 spawn 一次 WDA，之后禁止
#           respawn；拔出 USB → 清状态 → 重新插入又允许 spawn 一次。覆盖
#           "人工准备一次 / 长期复用 / 拔插作为唯一重置入口"的 95% 部署诉求。
#   false = 严格 attach-only。即使首次插入也要求外部已起 WDA（Xcode / 手工
#           xcodebuild / 独立守护进程）；适用于外部统一管 WDA 的严苛部署机房。
# auto 模式忽略本字段。
AI_PHONE_IOS_WDA_STABLE_ALLOW_INITIAL_SPAWN=true


# ─────────────────── 12. HarmonyOS 镜像后端 ───────────────────

# 鸿蒙镜像后端（agent 重启生效；不达预期改回 screenshot 立刻兜底）：
#   hypium      ：hypium Captures MJPEG socket 长连，~30fps，<100ms 延迟，
#                  折叠/异形屏天然自适应。**视频期间唯一可用**（含合成画面）
#   screenshot ：hdc shell snapshot_display 截图轮询，~8-10fps，
#                  视频期间 XComponent/SurfaceView 抓不到 → 全黑，hypium 不可用时兜底
AI_PHONE_HARMONY_MIRROR_BACKEND=hypium

# ─────────────────── 12.1 HarmonyOS 电源策略 ───────────────────

# HarmonyOS 插入/扫描时是否沿用旧的“长期常亮”策略。
# 作用层级：设备发现 / driver 打开阶段；不负责 Run 前唤醒。
#   true  = 历史行为：driver 打开时 power-shell timeout 长亮并周期续约。
#           适合调试期一直保持可见画面。
#   false = 不做长亮续约，允许设备按系统设置自然息屏。
#           适合“空闲黑屏省电，Run 前再唤醒”的部署方式。
# 本模板默认 false：采用“空闲息屏 + Run 前唤醒”线路。
AI_PHONE_HARMONY_SETUP_STAY_AWAKE=false

# HarmonyOS 黑屏时 readiness 是否仍允许派发。
# 作用层级：调度准入 / 设备总览状态。
# HarmonyOS 黑屏时常显示 screen_locked / 不可 Run；这会导致 Run 前 wake 没机会执行。
#   false = 历史行为：黑屏显示 screen_locked，不派发。
#   true  = 把“息屏但可 hdc wake”视为待机态，允许调度器派发。
# 本模板默认 true：黑屏待机设备仍可被调度，后续由 Run 前 hdc wake 拉起来。
AI_PHONE_HARMONY_SCREEN_OFF_DISPATCHABLE=true

# HarmonyOS VLM Run 开始前是否用纯 hdc 主动亮屏。
# 作用层级：首跑 / V1 / V2 / V3 缓存回放真正执行前。
# 该步骤发生在 hmdriver2 初始化 / 首张截图 / 缓存回放之前：
#   false = 历史行为：不额外唤醒。
#   true  = 先执行 hdc shell power-shell wakeup。
# 设计原因：黑屏时 hmdriver2 / uitest 可能还没恢复，必须用纯 hdc 做 preflight。
AI_PHONE_HARMONY_WAKE_BEFORE_RUN=true

# HarmonyOS wake 后是否允许“自动上滑”能力。
# 注意：这只是能力总开关；真正上滑由 Server/Web 的设备配置表决定。
# 作用层级：Run 前 power-shell wakeup 之后、首张截图 / 缓存回放之前。
#   false = 所有 HarmonyOS 都不会自动上滑。
#   true  = Server 下发 wake_policy.wake_swipe=true 的设备才允许上滑。
# 用途：部分鸿蒙机型 wake 后停在锁屏壁纸页，无人值守 Run 需要上滑进入可操作态。
# 手动进入工作台不走这个上滑逻辑，手动场景只 wake。
AI_PHONE_HARMONY_WAKE_SWIPE_ENABLED=true

# HarmonyOS wake 后等待屏幕点亮/锁屏壁纸渲染的时间，单位毫秒。
# 如果 hdc wake 后首帧仍黑，可调高。
AI_PHONE_HARMONY_WAKE_SETTLE_MS=500

# HarmonyOS 上滑后等待桌面/前台窗口恢复的时间，单位毫秒。
# 仅 HARMONY_WAKE_SWIPE_ENABLED=true 且 Server 下发 wake_policy.wake_swipe=true 时生效。
AI_PHONE_HARMONY_WAKE_SWIPE_SETTLE_MS=500

# HarmonyOS 进入工作台/启动镜像/手动 input 前是否主动点亮屏幕。
# 作用层级：手动进入工作台、启动/复用镜像、手动 input 前。
#   false = 历史行为：黑屏时手动进入可能仍看到黑屏，手点也可能不唤醒。
#   true  = 进入工作台 / 复用镜像 / 手动点击前先 hdc wake。
# 这里只 wake，不上滑；手动调试场景用户可以自己上滑，避免自动手势抢操作。
# 本模板默认 true：鸿蒙黑屏时手动进入工作台也先点亮，体验更接近可用设备。
AI_PHONE_HARMONY_WAKE_ON_ENTER=true


# ─────────────────── 13. 大盘展示开关 + 时区 + 对外可查窗口 ───────────────────

# 大盘卡片：token 消耗统计（外部展示前期可关掉）
AI_PHONE_ANALYTICS_SHOW_TOKEN=true

# 大盘卡片：稳定性统计（外部展示前期可关掉）
AI_PHONE_ANALYTICS_SHOW_STABILITY=true

# 大盘单日切片时区（IANA 名）。海外部署改成 America/Los_Angeles 等
AI_PHONE_ANALYTICS_TIMEZONE=Asia/Shanghai

# AI 分析最多允许往前查的天数（含今天）。默认 3 = 今天/昨天/前天
AI_PHONE_ANALYTICS_AI_MAX_AGE_DAYS=3

# 对外 API 可查窗口（天）。submission 终态后 N 天内 /api/submissions/<id> 可查
# + HTML 报告可访问；超过返回 404 expired。数据/文件清理另起任务。
AI_PHONE_SUBMISSION_EXTERNAL_RETENTION_DAYS=15


# ─────────────────── 14. Midscene 执行器（外接，可选）───────────────────
# 见 `Midscene执行器接入方案.md`。寄居在 ai-phone/midscene-bridge/ 的独立 Node 工程。
# 默认关闭：开关关闭时 ai-phone 主仓零行为变化。
# Midscene 自己的配置（VLM key / 模型名等）走 midscene-bridge/.env.midscene，与本文件完全独立。

# 是否暴露 Midscene 引擎（前端下拉框 / API 校验）
AI_PHONE_MIDSCENE_ENABLED=false

# Midscene run 单次硬超时（秒）。默认 60 分钟，给长链 case 留余量
AI_PHONE_MIDSCENE_RUN_TIMEOUT_SEC=3600

# midscene-bridge 目录路径（留空 = 自动定位到 <repo>/midscene-bridge）
# AI_PHONE_MIDSCENE_BRIDGE_DIR=/Users/me/projects/ai-phone/midscene-bridge

# Node 可执行文件路径（多版本 Node 时可写绝对路径）
AI_PHONE_MIDSCENE_NODE_BIN=node


# ─────────────────── 15. Submission 终态广播（Kafka）───────────────────
# Submission 每个 item 跑到终态后，scheduler 会把结果 JSON 推到 Kafka。
# 没接 Kafka 的开发场景留 stdout 即可：终态事件就只打到日志里，不影响主流程。
#
# 详细 payload 字段见 `backend/ai_phone/server/submissions/events.py` 的 build_terminal_event。
# v1 只发终态，不广播 queued/running 中间态。

# 广播 backend 选择：
#   stdout  - 默认。终态事件以 JSON 行打到 loguru（开发 / 单机够用）
#   kafka   - 真发到下面配置的 broker（生产 / 接外部消费方）
#   null    - 关掉广播（单测 / 演示）
AI_PHONE_BROADCAST_BACKEND=stdout

# Kafka bootstrap servers，逗号分隔。留空 → KafkaPublisher 自动降级 mock（只打日志）
# 例：AI_PHONE_KAFKA_BROKERS=kafka-1.example.com:9092
# 例：AI_PHONE_KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
AI_PHONE_KAFKA_BROKERS=

# Kafka topic。v1 固定，不建议改；多环境隔离请走多 broker 或 topic 前缀
AI_PHONE_KAFKA_TOPIC=ai-phone.submission.result

# SASL/PLAIN 鉴权；公司内网明文集群可不填
# 同时填 username + password 才会启用 SASL_PLAINTEXT；否则按 PLAINTEXT 连
AI_PHONE_KAFKA_SASL_USERNAME=
AI_PHONE_KAFKA_SASL_PASSWORD=


# ============================================================================
# 高级调优（§16-§20）：默认值都是经过实测的稳定值，"误 kill 多发"等异常运维
# 场景下才需要碰；普通用户保持默认即可。每个字段的物理含义和取值范围见
# backend/ai_phone/config.py 同名字段注释。
# ============================================================================


# ─────────────────── 16. Submission 调度 TTL ───────────────────
# scheduler 兜底超时：批次 / item 跑过这个时长强制收口，防止异常 agent 永远
# 不回 RUN_DONE 把队列死锁。**这两个值开源用户几乎一定要按业务调整**：
# 短任务嫌 1h item 太长（设备 stuck 1h 才回收），长 case 嫌 3h 批次太短。

# Submission（批次）总硬超时（秒）。从 admit 时刻开始计时，超过仍未收口则
# 强制把剩余 item 标 expired 并触发终态广播。默认 3 小时（10800）。
AI_PHONE_SUBMISSION_TTL_SEC=10800

# 单个 SubmissionItem 硬超时（秒）。item 进入 running 后超时仍无 RUN_DONE
# 则强制 finalize 为 timeout。默认 1 小时（3600），覆盖典型业务 case。
AI_PHONE_ITEM_TTL_SEC=3600

# scheduler 后台 tick 周期（秒）。事件驱动路径会主动 kick，这是兜底巡检。
# 短任务高吞吐场景可调小（0.5-1s）；空闲集群可调大省 CPU。
AI_PHONE_SCHEDULER_TICK_SEC=2.0

# 功能地图上下文（执行参考）注入开关。关闭时字段仍接收/落库/校验，
# 但不会注入主 VLM。用于一键回退到无参考资料的现状行为。
AI_PHONE_FUNCTION_MAP_CONTEXT_ENABLED=true

# functionMapContext 字符上限；0 表示不做产品层长度拦截。
# 设置正整数后超限拒绝，不自动截断。
AI_PHONE_FUNCTION_MAP_CONTEXT_MAX_CHARS=0

# 失败自动重跑。默认关闭；开启后，用户传入 retryMax 会被 RUN_RETRY_MAX 截断。
# RUN_RETRY_MAX 是“最多重跑几次”，不含首跑；3 表示最多 1 次首跑 + 3 次重跑。
AI_PHONE_RUN_RETRY_ENABLED=true
AI_PHONE_RUN_RETRY_MAX=3
# 失败后进入下一次 attempt 前是否删除当前 cacheMode 对应轨迹缓存。
AI_PHONE_RUN_RETRY_CLEAR_CACHE=true
# 失败 attempt 和下一次 attempt 之间的冷却秒数。
AI_PHONE_RUN_RETRY_COOLDOWN_SEC=2.0


# ─────────────────── 17. Run 行为硬上限 ───────────────────

# 单 Run 最大决策步数硬上限。超过强制 fail 收尾，防 VLM 在死路打转烧 token。
# 长链 case（>30 步）适当调大；常规短 case 100 已经偏宽松。
AI_PHONE_RUN_MAX_STEPS=100

# 单次 wait action 最大允许等待秒数（VLM 申请超过该值会被裁剪并标 clipped）。
# 默认 30 分钟（1800）为长等场景兜底；常规业务可调到 60-300s。
AI_PHONE_RUN_MAX_WAIT_SEC=1800

# VLM 主通道页面稳定检测参数。false=直接截图放行，不做像素哈希等待；
# 业务流程不会中断，但 VLM 可能拿到动画中间帧。
AI_PHONE_VLM_PAGE_STABLE_ENABLED=true
AI_PHONE_VLM_PAGE_STABLE_TIMEOUT_S=5.0
AI_PHONE_VLM_PAGE_STABLE_POLL_S=0.4
AI_PHONE_VLM_PAGE_STABLE_THRESHOLD=0.04

# 旧 V2 回放总开关，保留兼容；新方案主要由下面的
# AI_PHONE_TRAJECTORY_CACHE_ENABLED + payload cacheMode 决定是否生效。
AI_PHONE_VLM_TRAJECTORY_CACHE_REPLAY_ENABLED=true

# 轨迹缓存回放通道页面稳定检测参数。只影响“命中缓存后的回放”，不影响首跑 VLM。
# 业务场景：缓存 action 执行后，如果没有状态路标可用，或状态路标功能关闭/缺图，
# 会退回这套像素稳定检测，避免页面还在加载时继续点下一步。
# 想最快：可以关闭或缩短 timeout；想稳一点：保持开启，必要时调大 timeout。
# 统一总开关。true 时 Run/submission 的 cacheMode=off/v1/v2/v3 才会生效；
# false 时 requested_cache_mode 会保留请求值，但 effective_cache_mode 会静默落为 off。
AI_PHONE_TRAJECTORY_CACHE_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_ENABLED=true
# 单次稳定检测最多等几秒。设备卡、页面加载慢、WebView 慢时调大；追求速度时调小。
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_TIMEOUT_S=5.0
# 稳定检测多久截一次图。越小越灵敏但截图次数更多；常规 0.3-0.5s。
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_POLL_S=0.4
# 两次截图差异小于等于该值认为页面稳定。越小越严格；动态视频/运营位多时可能误等。
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_THRESHOLD=0.04
# 缓存回放 action 后，先固定等一小段再截图观察。业务场景：避开点击水波纹、
# 跳转初始白屏、按钮按压态等早期中间帧。0=关闭；通常 300-800ms。
AI_PHONE_TRAJECTORY_CACHE_OBSERVE_DELAY_MS=500
# v2 状态路标对齐总开关。开启后，每个缓存 action 后会拿“当前截图”和
# “首次成功轨迹中该 action 的 handoff 图”做严格对齐。
# MATCH：认为轨迹仍贴合，跳过完整页面稳定检测，速度快。
# MISS：按首次成功 action 间隔等待并重比；仍 MISS 才进入 recovery_vlm 或直接失败。
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_ENABLED=true
# 整页 pHash 差异阈值。越小越严格。业务场景：想更早发现点错页/内容换页就调小；
# 页面有少量动态内容但业务不受影响，可略调大。
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_THRESHOLD=0.03
# 中心区域像素差阈值，用来补 pHash 对大布局不敏感的问题。越小越严格。
# 业务场景：弹窗、列表主体、内容区变化明显时靠它拦截；视频帧变化大时可能更敏感。
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_ROI_THRESHOLD=0.25
# 黑屏/白屏/加载页比例差阈值。业务场景：防止白屏、黑屏、loading 页面被误判成可继续。
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_BLACK_RATIO_THRESHOLD=0.15
# 状态路标 MISS 后每隔多久重新截图一次。越小发现恢复越快，但截图更频繁。
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_RETRY_INTERVAL_MS=300
# 状态路标 MISS 后至少等多久再放弃。业务场景：轻微加载/短动画给一点恢复时间。
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_MIN_WAIT_MS=1000
# 状态路标等待窗口 = max(最小等待, 首次成功 action 间隔 * 该系数)。
# 业务场景：首跑这一步本来就加载 8s，回放也应允许接近这个时间再判失败。
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_MAX_WAIT_RATIO=1.3
# v2 缓存回放 alignment_miss 后的 VLM 专线。
# 通道完全独立：与辅助系统 / 断言系统 / 主 VLM 全部分离，没有 fallback。
# 业务场景：状态路标严格对不上时，让 VLM 看 goal + 首次 handoff 图 + 当前图，
# 判断是功能真错、还在加载、动态内容可放行，还是可做少量局部修复。
# false：不问 VLM；等待窗口耗尽后直接 alignment_miss / assert_fail。
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_ENABLED=true
# 专线协议。三家 backend 与主 VLM 一一对应，建议跟主 VLM 同家：
#   - doubao_responses : 火山方舟 /responses（豆包系，主 VLM=doubao_responses 配这个）
#   - openai_compatible: 通用 chat completions（豆包 /chat、自建代理、OpenAI 都属此类）
#   - claude_messages  : Anthropic /v1/messages（主 VLM=claude_cu 配这个）
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_BACKEND=doubao_responses
# 专线接口地址。典型做法是复制主 VLM 地址，但保留独立字段便于单独切模型/切代理。
#   - doubao_responses : https://ark.cn-beijing.volces.com/api/v3/responses
#   - openai_compatible: https://ark.cn-beijing.volces.com/api/v3/chat/completions
#                        或 https://api.openai.com/v1/chat/completions
#   - claude_messages  : https://api.anthropic.com/v1/messages
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_API_URL=
# 专线 key。不要提交真实 key；本地 .env 可复制主 VLM key。
# claude_messages 走 anthropic key（sk-ant-*）；其余走对应 backend 的 key。
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_API_KEY=
# 专线模型。建议先与主 VLM 同款，避免“主 VLM 能看懂、恢复 VLM 看不懂”。
#   - doubao : doubao-seed-1-6-vision-250815
#   - openai : gpt-4o / computer-use-preview
#   - claude : claude-sonnet-4-5 / claude-haiku-4-5
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_MODEL=
# 专线单次调用超时。网络慢/模型慢时调大；超时会按保守失败处理。
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_TIMEOUT_SEC=30
# VLM 判“还在加载，再等等”时默认多等多久。业务场景：页面确实慢加载但不是偏航。
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_WAIT_MORE_MS=1500
# 单个 action 对齐失败时，最多接受几次 VLM 要求继续等待。超过说明不健康，失败。
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_MAX_WAIT_MORE=1
# 单个 action 对齐失败时，VLM 最多执行多少个局部修复动作。
# 业务场景：关弹窗、返回一步、补一次输入/滑动/点击等。0=禁止修复，只裁决。
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_MAX_REPAIR_ACTIONS=5
# 单条缓存回放最多召唤 recovery_vlm 几次。业务场景：连续多步都需要救场，
# 说明 case 起跑状态/cache/业务环境不健康，直接失败，避免越救越慢。
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_MAX_CALLS_PER_REPLAY=5

# V3 语义回放 coord / rescue 专线。
# claude_cu/gpt_cu 坐标定位固定复用主 VLM 能力配置；这里只调定位专线的推理强度/超时。
# 非 CU 历史路径默认复用上面的 recovery_vlm 连接配置。
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_USE_RECOVERY_VLM_CONFIG=true
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_BACKEND=doubao_responses
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_API_URL=
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_API_KEY=
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_MODEL=
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_CLAUDE_THINKING_BUDGET=0
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_GPT_REASONING_EFFORT=low
# 坐标没找到时直接进入 V3 rescue，由辅助模型决定等待、局部修复、继续衔接或放弃。
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_USE_RECOVERY_VLM_CONFIG=true
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_BACKEND=doubao_responses
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_API_URL=
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_API_KEY=
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_MODEL=
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_MAX_CALLS_PER_REPLAY=3

# v2 瞬态弹窗动作标记与按需回放总开关。
# false：不做 classifier，不做 gate，旧 V2 缓存回放完全不变。
# true：成功轨迹保存时可把明确的非业务瞬态清障 action 标为 optional_ephemeral；
# 回放遇到该 action 时先问 gate，确认弹窗不存在才跳过。
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_ACTION_ENABLED=true
# 保存阶段是否启用 classifier。总开关打开但这里关掉时，只写默认 business_required。
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFY_ENABLED=true
# classifier 默认复用辅助模型 ASSISTANT_*；仅当下面 URL/key/model 任一非空时，
# 才使用这组独立配置。backend 可选：
#   - openai_compatible: 豆包 /chat、OpenAI /chat/completions、自建兼容代理
#   - openai_responses : OpenAI /responses
#   - claude_messages  : Anthropic /v1/messages
#   - doubao_responses : 火山方舟 /responses
# thinking/reasoning：豆包 chat 自动 thinking.enabled；OpenAI 自动 reasoning_effort=medium；
# Claude 自动使用 vlm_main_thinking_budget。
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFIER_BACKEND=openai_compatible
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFIER_API_URL=
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFIER_API_KEY=
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFIER_MODEL=
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFIER_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFY_MIN_CONFIDENCE=0.85
# 回放阶段 gate。只对 optional_ephemeral action 调用；普通业务 action 不受影响。
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_ENABLED=true
# 默认复用 recovery_vlm 的连接配置，但使用完全独立的 gate prompt。
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_USE_RECOVERY_VLM_CONFIG=true
# 如果上面设为 false，则使用下面这组独立 gate 连接配置。海外主 VLM 场景建议：
#   - 主 VLM=claude_cu → gate/recovery backend=claude_messages
#   - 主 VLM=gpt_cu    → gate/recovery backend=openai_responses
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_BACKEND=openai_compatible
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_API_URL=
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_API_KEY=
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_MODEL=
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_TIMEOUT_SEC=30
# 单条缓存回放最多调用 gate 几次，防止误标/弹窗过多导致成本失控。
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_MAX_CALLS=3

# 结构化通道审判（_run_struct_audit）单次调用超时（秒）。
# 超时按 ALLOW 处理不阻塞 Run；网络环境差/海外节点可调到 60-90s。
AI_PHONE_AUDIT_TIMEOUT_SEC=30

# 断言系统（finished 终局裁决）单次调用超时（秒）。
# 超时按 SKIP 处理回退主 VLM 结果，不阻塞 Run 收尾。
AI_PHONE_ASSERTION_TIMEOUT_SEC=60

# 审判系统单 Run 累计 ALLOW 次数上限。达上限后探测器召唤直接 KILL 绕过审判。
# 审判模型不稳/容易误 KILL 时调大（50-100）；想让 Run 早死省 token 调小。
# 默认 30 已经是"效果优先"取值——再嫌严格直接调大。
AI_PHONE_AUDIT_ALLOW_LIMIT=30

# 审判周期巡检间隔（步）。每 N 步主动召唤一次审判检查推进合理性。
# 0 = 关闭周期巡检（仅 detector 触发）；调大让 VLM 多跑几步再检查。
# 历史经验：5 太频繁前期合法跳步常被误 KILL，30 给足 VLM 上下文再监督。
AI_PHONE_AUDIT_PERIODIC_INTERVAL=30

# 单轮 VLM 决策最多串联多少个 Action（超出截断保留前 N 个）。
# 1 = 关闭链式（每步只走一个 Action）；视频/工具栏场景需要 ≥ 2。
AI_PHONE_CHAIN_MAX_ACTIONS=2

# 链内相邻两个 Action 的硬等间隔（毫秒）。
# 0 = 不等（极激进）；过大让链式失去毫秒级追瞬态 UI 的意义。
AI_PHONE_CHAIN_INNER_GAP_MS=200


# ─────────────────── 18. 卡死检测阈值 ───────────────────
# 这一组是本地纯算法（不调 LLM）的兜底卡死探测器。命中后会向 VLM 注入
# "卡死提示"或直接终止 Run。阈值偏小 → 误 kill 多发；偏大 → 真死循环
# 拖太久。**误 kill 多发场景，把这一组阈值整体调大 1-2 档**。

# 同坐标连续点击触发卡死提示的次数。点过 N 次同位置仍无屏变化 → 注入提示。
# 历史默认 4 在「VLM 第 1-3 次反复点已满足按钮」期间无任何干预，配合强制
# 判读句协议从 4 → 2，第 2 次同位置就立即提示「目标可能已满足」。
# 真有合法连点场景（刷新按钮/抽奖）可调回 3-4。
AI_PHONE_CLICK_STUCK_THRESHOLD=2

# 同方向连续无效滚动触发卡死提示的次数。N 次 swipe 屏幕几乎不动 → 注入提示。
# 长列表底部场景调大；常规列表保持默认。
AI_PHONE_SCROLL_STUCK_THRESHOLD=8

# VLM 连续输出未知 / 解析失败 action 的次数上限。超过 → 注入纠正提示。
# 模型偶尔抖动可调到 5；想严格收口调到 2。
AI_PHONE_UNKNOWN_ACTION_STREAK_LIMIT=3

# 连续截图失败次数上限。超过 → 终止 Run 标 fail（设备可能掉线/崩溃）。
# 弱网/老旧设备可调到 5-8；线上稳定环境保持默认。
AI_PHONE_CONSECUTIVE_SCREENSHOT_FAIL_LIMIT=3


# ─────────────────── 19. 异常介入触发阈值（结构化通道审判 detector）───────────────────
# 这一组是"召唤审判"的本地探测器阈值。命中后**不直接 kill**，丢给轻量审判
# 模型判定继续 / 终止。阈值偏小 → 频繁召唤审判（多 token 多延迟）；偏大 →
# 真偏离也叫不醒审判。"误 kill 多发"运维场景的关键调节区。

# 同坐标桶聚类容差（像素，质心欧氏距）。距离 ≤ 此值视为同一桶。
# 高分屏可调大（80-100）；密集 UI 调小（20-30）。
AI_PHONE_AUDIT_CLICK_BUCKET_PX=50

# 同坐标桶累计 click ≥ N 次召唤审判。
# 调大允许更多合法重试；调小快速发现反复点同一处模式。
# 历史值 3 在长 case / 多视觉证据复点场景偏严，频繁误召唤，调到 10。
AI_PHONE_AUDIT_CLICK_BUCKET_TRIGGER=10

# pHash 汉明距阈值，≤ 此值视为同屏。256 bit 哈希默认 8 ≈ 3% 差异。
# 调小（4-6）严格判同屏；调大（12-16）容忍更多视觉抖动。
AI_PHONE_AUDIT_SCREEN_REVISIT_HAMMING=8

# 同屏访问累计 ≥ N 次召唤审判。Tab 切换 / 抽屉开合等合法多次访问可调大。
# 历史值 3 在"同一页面找多个视觉证据"场景偏严，调到 10。
AI_PHONE_AUDIT_SCREEN_REVISIT_TRIGGER=10

# 滚动方向翻转检测窗口（最近 N 次滚动）。
AI_PHONE_AUDIT_SCROLL_FLIP_WINDOW=10

# 窗口内方向翻转 ≥ N 次召唤审判（震荡 / 东找西找）。
# 长列表上下找东西天然有方向变化，历史值 2 偏严，调到 6。
AI_PHONE_AUDIT_SCROLL_FLIP_TRIGGER=6

# 滚动前后帧 diff_rate ≤ 此值视为页面几乎没动（无效滑动）。
# 调大（0.05）容忍更多视觉抖动；调小（0.005）严格判无效滑动。
AI_PHONE_AUDIT_SCROLL_NOPROGRESS_DIFF=0.02

# 同方向连续无效滑动 ≥ N 次召唤审判（已到列表底/无更多内容场景）。
# 长页面翻 6-7 次找内容是正常行为，历史值 3 偏严，调到 10。
AI_PHONE_AUDIT_SCROLL_NOPROGRESS_TRIGGER=10


# ─────────────────── 20. 通道判定阈值（结构化 vs 自由对话）───────────────────
# 启动期判定 case 走哪条通道：结构化（带审判 + 严格步骤校验）还是自由对话
# （VLM 自主决策）。阈值控制"严格度多高才进结构化"。
#   关键字命中 ≥ HARD_HIT       → 直接结构化（最高置信，免审判分类调用）
#   严格度评分 ≥ HARD_SCORE     → 直接结构化（长 case + 密集约束）
#   严格度评分 ≥ AUDIT_SCORE    → 借审判模型一次性分类
#   都不达标                     → 自由对话通道

# 四级标签命中数 ≥ 此值直接走结构化（免审判分类调用）。
# 标签：测试标题/前置条件/操作步骤/预期结果/起跑线/资源选择/兜底等。
AI_PHONE_STRUCT_KEYWORD_HARD_HIT=2

# 严格度综合评分 ≥ 此值直接走结构化（0-7 分制）。
# 默认 10：关闭“靠严格度评分直接进结构化”，只保留标签命中入口。
AI_PHONE_STRUCT_STRICTNESS_HARD_SCORE=10

# 严格度评分 ≥ 此值借审判模型分类（中等信号 case）。
# 默认 10：关闭“靠严格度评分借审判模型进结构化”，只保留标签命中入口。
AI_PHONE_STRUCT_STRICTNESS_AUDIT_SCORE=10
