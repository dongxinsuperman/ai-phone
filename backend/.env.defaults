# ============================================================================
# ai-phone backend/.env.defaults
#
# Runtime defaults that are safe to commit.
# Do not put API keys, database passwords, Apple Team IDs, personal paths,
# private URLs, or real tokens in this file.
#
# Load order:
#   code defaults < .env.defaults < .env < .env.local < process environment
# ============================================================================


# ─────────────────── Runtime / Server Defaults ───────────────────
AI_PHONE_ENV=local
AI_PHONE_LOG_LEVEL=INFO
AI_PHONE_STORAGE_DIR=./.data/storage
AI_PHONE_SERVER_HOST=0.0.0.0
AI_PHONE_SERVER_PORT=8000
AI_PHONE_CORS_ORIGINS=["http://127.0.0.1:5180","http://localhost:5180"]


# ─────────────────── Model Behavior Defaults ───────────────────
AI_PHONE_VLM_SESSION_RESET_PROMPT_THRESHOLD=30000
AI_PHONE_VLM_CU_ZH_PROMPT_ENABLED=false
AI_PHONE_VLM_MAIN_THINKING_BUDGET=1024
AI_PHONE_VLM_HISTORY_WINDOW_STEPS=12
AI_PHONE_VLM_MAIN_REASONING_EFFORT=medium
AI_PHONE_VLM_MAIN_PROMPT_CACHING_ENABLED=false
AI_PHONE_ASSISTANT_THINKING_JUDGE=true
AI_PHONE_ASSISTANT_THINKING_ASSERTION=true


# ─────────────────── Transient UI Defaults ───────────────────
AI_PHONE_TRANSIENT_UI_ENABLED=true
AI_PHONE_TRANSIENT_UI_KEYWORDS=视频,播放,倍速,直播,video,player,play,toast
AI_PHONE_TRANSIENT_UI_LATE_DELAY_MS=6000


# ─────────────────── Android Power / Mirror Defaults ───────────────────
AI_PHONE_ANDROID_SETUP_STAY_AWAKE=false
AI_PHONE_ANDROID_SCREEN_OFF_DISPATCHABLE=true
AI_PHONE_ANDROID_WAKE_BEFORE_RUN=true
AI_PHONE_ANDROID_WAKE_BEFORE_RUN_SETTLE_MS=500
AI_PHONE_ANDROID_WAKE_ON_ENTER=false
AI_PHONE_MIRROR_MAX_WIDTH=1280
AI_PHONE_MIRROR_MAX_FPS=30
AI_PHONE_MIRROR_BITRATE=6000000
AI_PHONE_MIRROR_FRAG_MS=50
AI_PHONE_MIRROR_GOP_SEC=1


# ─────────────────── iOS Runtime Defaults ───────────────────
AI_PHONE_IOS_MIRROR_BACKEND=mjpeg_passthrough
AI_PHONE_WDA_MJPEG_LONG_EDGE=1280
AI_PHONE_WDA_MJPEG_QUALITY=80
AI_PHONE_WDA_MJPEG_FPS=20
AI_PHONE_IOS_WDA_PRELOAD=true
AI_PHONE_IOS_WAKE_ON_ENTER=true
AI_PHONE_IOS_SCREEN_OFF_DISPATCHABLE=true
AI_PHONE_IOS_WAKE_BEFORE_RUN=true
AI_PHONE_IOS_WAKE_BEFORE_RUN_SETTLE_MS=500
AI_PHONE_IOS_WDA_LIFECYCLE_MODE=stable
AI_PHONE_IOS_WDA_STABLE_ALLOW_INITIAL_SPAWN=true


# ─────────────────── HarmonyOS Runtime Defaults ───────────────────
AI_PHONE_HARMONY_MIRROR_BACKEND=hypium
AI_PHONE_HARMONY_SETUP_STAY_AWAKE=false
AI_PHONE_HARMONY_SCREEN_OFF_DISPATCHABLE=true
AI_PHONE_HARMONY_WAKE_BEFORE_RUN=true
AI_PHONE_HARMONY_WAKE_SWIPE_ENABLED=true
AI_PHONE_HARMONY_WAKE_SETTLE_MS=500
AI_PHONE_HARMONY_WAKE_SWIPE_SETTLE_MS=500
AI_PHONE_HARMONY_WAKE_ON_ENTER=true


# ─────────────────── Analytics / Submission Defaults ───────────────────
AI_PHONE_ANALYTICS_SHOW_TOKEN=true
AI_PHONE_ANALYTICS_SHOW_STABILITY=true
AI_PHONE_ANALYTICS_TIMEZONE=Asia/Shanghai
AI_PHONE_ANALYTICS_AI_MAX_AGE_DAYS=3
AI_PHONE_SUBMISSION_EXTERNAL_RETENTION_DAYS=15
AI_PHONE_BROADCAST_BACKEND=stdout
AI_PHONE_KAFKA_TOPIC=ai-phone.submission.result
AI_PHONE_SUBMISSION_TTL_SEC=10800
AI_PHONE_ITEM_TTL_SEC=3600
AI_PHONE_SCHEDULER_TICK_SEC=2.0
AI_PHONE_ORPHAN_REAP_GRACE_SEC=60.0


# ─────────────────── Function Map Defaults ───────────────────
AI_PHONE_FUNCTION_MAP_CONTEXT_ENABLED=true
AI_PHONE_FUNCTION_MAP_CONTEXT_MAX_CHARS=0


# ─────────────────── Retry / Run Limits Defaults ───────────────────
AI_PHONE_RUN_RETRY_ENABLED=true
AI_PHONE_RUN_RETRY_MAX=3
AI_PHONE_RUN_RETRY_CLEAR_CACHE=true
AI_PHONE_RUN_RETRY_COOLDOWN_SEC=2.0
AI_PHONE_RUN_MAX_STEPS=100
AI_PHONE_RUN_MAX_WAIT_SEC=1800
AI_PHONE_VLM_PAGE_STABLE_ENABLED=true
AI_PHONE_VLM_PAGE_STABLE_TIMEOUT_S=5.0
AI_PHONE_VLM_PAGE_STABLE_POLL_S=0.4
AI_PHONE_VLM_PAGE_STABLE_THRESHOLD=0.04


# ─────────────────── Trajectory Cache Defaults ───────────────────
AI_PHONE_VLM_TRAJECTORY_CACHE_REPLAY_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_TIMEOUT_S=5.0
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_POLL_S=0.4
AI_PHONE_TRAJECTORY_CACHE_PAGE_STABLE_THRESHOLD=0.04
AI_PHONE_TRAJECTORY_CACHE_OBSERVE_DELAY_MS=500
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_THRESHOLD=0.03
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_ROI_THRESHOLD=0.25
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_BLACK_RATIO_THRESHOLD=0.15
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_RETRY_INTERVAL_MS=300
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_MIN_WAIT_MS=1000
AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_MAX_WAIT_RATIO=1.3
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_WAIT_MORE_MS=1500
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_MAX_WAIT_MORE=1
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_MAX_REPAIR_ACTIONS=5
AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_MAX_CALLS_PER_REPLAY=5
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_USE_RECOVERY_VLM_CONFIG=true
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_CLAUDE_THINKING_BUDGET=0
AI_PHONE_TRAJECTORY_CACHE_V3_COORD_GPT_REASONING_EFFORT=low
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_USE_RECOVERY_VLM_CONFIG=true
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_V3_RESCUE_MAX_CALLS_PER_REPLAY=3
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_ACTION_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFY_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFIER_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_CLASSIFY_MIN_CONFIDENCE=0.85
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_ENABLED=true
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_USE_RECOVERY_VLM_CONFIG=true
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_TIMEOUT_SEC=30
AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_GATE_MAX_CALLS=3


# ─────────────────── Audit / Action Guard Defaults ───────────────────
AI_PHONE_AUDIT_TIMEOUT_SEC=30
AI_PHONE_ASSERTION_TIMEOUT_SEC=60
AI_PHONE_AUDIT_ALLOW_LIMIT=30
AI_PHONE_AUDIT_PERIODIC_INTERVAL=30
AI_PHONE_CHAIN_MAX_ACTIONS=2
AI_PHONE_CHAIN_INNER_GAP_MS=200
AI_PHONE_CLICK_STUCK_THRESHOLD=2
AI_PHONE_SCROLL_STUCK_THRESHOLD=8
AI_PHONE_UNKNOWN_ACTION_STREAK_LIMIT=3
AI_PHONE_CONSECUTIVE_SCREENSHOT_FAIL_LIMIT=3
AI_PHONE_AUDIT_CLICK_BUCKET_PX=50
AI_PHONE_AUDIT_CLICK_BUCKET_TRIGGER=10
AI_PHONE_AUDIT_SCREEN_REVISIT_HAMMING=8
AI_PHONE_AUDIT_SCREEN_REVISIT_TRIGGER=10
AI_PHONE_AUDIT_SCROLL_FLIP_WINDOW=10
AI_PHONE_AUDIT_SCROLL_FLIP_TRIGGER=6
AI_PHONE_AUDIT_SCROLL_NOPROGRESS_DIFF=0.02
AI_PHONE_AUDIT_SCROLL_NOPROGRESS_TRIGGER=10
# 结构化通道默认只做标签准入：严格度评分最高 7，阈值设为 10 等于关闭评分入口。
AI_PHONE_STRUCT_KEYWORD_HARD_HIT=2
AI_PHONE_STRUCT_STRICTNESS_HARD_SCORE=10
AI_PHONE_STRUCT_STRICTNESS_AUDIT_SCORE=10


# ─────────────────── Midscene Defaults ───────────────────
AI_PHONE_MIDSCENE_ENABLED=false
AI_PHONE_MIDSCENE_RUN_TIMEOUT_SEC=3600
