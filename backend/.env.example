# ============================================================================
# ai-phone backend/.env.example
#
# This file is the user-facing fill-in template.
#
# Files and responsibilities:
#   .env.defaults     runtime defaults committed with the project
#   .env.example      this guide; copy to .env and fill real deployment values
#   .env.full.example full advanced reference; not loaded at runtime
#   .env              real deployment config; never commit
#   .env.local        local machine override; never commit
#
# Load order:
#   code defaults < .env.defaults < .env < .env.local < process environment
# ============================================================================


# ─────────────────── 1. Server 基础连接 ───────────────────
#
# 这一段让 Server 能启动、能连数据库、能校验 Agent 身份。
# 单机开发和生产部署都需要填；生产不要使用默认 token。

# Server 用来存任务、设备、运行记录的数据库。
# 本地开发可以用本机 PostgreSQL；生产要换成真实数据库。
AI_PHONE_DB_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<db>

# Server 和 Agent 共用的连接令牌。
# Agent 连接 Server 时会带这个 token；Server 用它校验 Agent 身份。
AI_PHONE_AGENT_TOKEN=<change-me>


# ─────────────────── 2. 模型配置 ───────────────────
#
# 这一段告诉 Server 用哪家模型。
# Server 会把这组配置派生后下发给 Agent；Agent 本机通常不需要再填模型 key。
#
# PHONE_VLM = 碰手机的主视觉模型，负责截图决策、点击、滑动、输入、完成判断。
# AUX       = 不碰手机的辅助模型，负责包名/通道/审判/断言/瞬态分类/大盘分析。
#
# AUX 必须显式配置，不能留空跟随 PHONE_VLM。

# 主 VLM provider。可选：doubao / claude / openai。
AI_PHONE_PHONE_VLM_PROVIDER=doubao

# 主 VLM 模型名。
# doubao 填 vision 模型；Claude 填支持 Computer Use 的模型；
# OpenAI 填 computer-use-preview。
AI_PHONE_PHONE_VLM_MODEL=doubao-seed-1-6-vision-250815

# 主 VLM API Key。不要提交真实 key。
AI_PHONE_PHONE_VLM_API_KEY=<model-api-key>

# 主 VLM API 根地址。
# doubao 填到 /api/v3；Claude 可填 https://api.anthropic.com；
# OpenAI 可填 https://api.openai.com/v1。
AI_PHONE_PHONE_VLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# AUX provider。可选：doubao / claude / openai。
AI_PHONE_AUX_PROVIDER=doubao

# AUX 模型名。建议用通用版/便宜快档，不要用主执行的 Computer Use 模型。
AI_PHONE_AUX_MODEL=doubao-seed-1-6-250615

# AUX API Key。可以和主 VLM 同一把 key，但也要显式填写。
AI_PHONE_AUX_API_KEY=<aux-api-key>

# AUX API 根地址。
# doubao 填到 /api/v3；Claude 填 https://api.anthropic.com；
# OpenAI 填 https://api.openai.com/v1。
AI_PHONE_AUX_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包额外手动步骤：
# 登录火山方舟控制台，为所用模型/接入点开启“上下文缓存（主动缓存）”。
# 不开不会影响连通性，但长任务 token 成本会明显变高。


# ─────────────────── 3. Agent 连接 Server ───────────────────
#
# 这一段只给 Agent 机器用。
# 作用是告诉这台 Agent 去连哪个 Server、用哪个 token。
# 如果 Server 和 Agent 在同一台机器，默认 127.0.0.1 可以直接用。

# Agent 接收 Server 派发任务和配置的 WebSocket 地址。
AI_PHONE_SERVER_WS_URL=ws://127.0.0.1:8000/ws/agent

# Agent 上传截图/文件、拉缓存图片时使用的 HTTP 地址。
AI_PHONE_SERVER_HTTP_BASE=http://127.0.0.1:8000

# Agent 展示名。留空时默认使用 hostname。
AI_PHONE_AGENT_NAME=


# ─────────────────── 4. iOS / WDA 本机配置 ───────────────────
#
# 这一段只和接 iPhone 有关。
# 它不是 Server 策略，而是每台 Mac 自己的 Xcode / 签名 / WDA 信息。
# 只跑 Android/HarmonyOS 可以留空。
# 多台 Mac 不同值时，建议放在各自机器的 .env.local。

# WebDriverAgent 工程目录，必须是本机真实路径。
AI_PHONE_WDA_PROJECT_DIR=

# WDA 的 Bundle ID，需要和 Xcode 签名配置一致。
AI_PHONE_WDA_BUNDLE_ID=

# Apple Developer Team ID。每个账号/团队不同，不要放进 .env.defaults。
AI_PHONE_WDA_TEAM_ID=

# WDA scheme。通常保持 WebDriverAgentRunner。
AI_PHONE_WDA_SCHEME=WebDriverAgentRunner


# ─────────────────── 5. Server 对外访问 ───────────────────
#
# 这一段控制 Server 监听端口、前端跨域和内部投递 token。
# 本地开发通常不用改；部署到公司域名、网关、反向代理时再改。

# Server HTTP/WS 监听地址。0.0.0.0 表示允许局域网访问。
AI_PHONE_SERVER_HOST=0.0.0.0

# Server HTTP/WS 端口。
AI_PHONE_SERVER_PORT=8000

# 前端域名白名单，必须是 JSON 数组格式。
# 改前端域名或线上域名时要同步改这里，否则浏览器会报跨域。
AI_PHONE_CORS_ORIGINS=["http://127.0.0.1:5180","http://localhost:5180"]

# 外部系统/前端提交任务时用的内部 Bearer token。
# 留空时复用 AI_PHONE_AGENT_TOKEN。
AI_PHONE_SUBMISSION_INTERNAL_TOKEN=


# ─────────────────── 6. Kafka / 结果广播 ───────────────────
#
# 这一段用于把 submission 终态结果广播给外部系统。
# 不接 Kafka 时保持 stdout；只有生产要接外部消费方时才填 Kafka。

# 可选：stdout / kafka / null。
AI_PHONE_BROADCAST_BACKEND=stdout

# Kafka broker 列表。只有 BROADCAST_BACKEND=kafka 时需要填。
AI_PHONE_KAFKA_BROKERS=

# Kafka 鉴权用户名。没有 SASL 可留空。
AI_PHONE_KAFKA_SASL_USERNAME=

# Kafka 鉴权密码。不要提交真实密码。
AI_PHONE_KAFKA_SASL_PASSWORD=


# ─────────────────── 7. Agent 本机文件和工具路径 ───────────────────
#
# 这一段是这台机器自己的路径。
# 多数情况下可以使用 .env.defaults / 代码默认值；同机多 Agent 或特殊路径再填。

# 本机截图、报告、调试文件缓存目录。
AI_PHONE_STORAGE_DIR=./.data/storage

# Midscene bridge 目录。留空时自动定位到 <repo>/midscene-bridge。
AI_PHONE_MIDSCENE_BRIDGE_DIR=

# Node 可执行文件路径。多版本 Node 或非默认 PATH 时再填绝对路径。
AI_PHONE_MIDSCENE_NODE_BIN=node


# ─────────────────── 8. 按需覆盖默认策略 ───────────────────
#
# 默认策略都在 .env.defaults 里。
# 只有你明确要覆盖项目默认行为时，才把对应变量复制到 .env 或 .env.local。
#
# 示例：functionMapContext 是外部提交任务时附带的“功能地图/业务背景”。
# Server 会按下面上限校验，超限直接拒绝，不截断。
# 默认值在 .env.defaults 中是 8000；如需改小或改大，再取消注释覆盖。
# AI_PHONE_FUNCTION_MAP_CONTEXT_MAX_CHARS=8000

# 当前项目默认策略快照如下；这些已经在 .env.defaults 生效，通常不要写进 .env。
# 如果某个部署环境确实要改行为，再复制对应一行到 .env 或 .env.local 覆盖。
#
# iOS 插线后默认预热 WDA，减少首次进入工作台等待。
# AI_PHONE_IOS_WDA_PRELOAD=true
#
# Run 失败默认允许按系统上限重试。
# AI_PHONE_RUN_RETRY_ENABLED=true
#
# 缓存回放默认启用；具体任务是否命中还受 payload cacheMode 和缓存数据影响。
# AI_PHONE_VLM_TRAJECTORY_CACHE_REPLAY_ENABLED=true
# AI_PHONE_TRAJECTORY_CACHE_ENABLED=true
# AI_PHONE_TRAJECTORY_CACHE_ALIGNMENT_ENABLED=true
# AI_PHONE_TRAJECTORY_CACHE_RECOVERY_VLM_ENABLED=true
# AI_PHONE_TRAJECTORY_CACHE_EPHEMERAL_ACTION_ENABLED=true
#
# 同方向无效滚动默认 8 次才触发卡死提示，避免长列表误判。
# AI_PHONE_SCROLL_STUCK_THRESHOLD=8

# 示例：结构化通道默认只做标签准入。
# 严格度评分最高 7，下面两个阈值默认是 10，表示不会因为“看起来很严格”就进结构化。
# 只有命中足够的结构化标签（如测试标题/操作步骤/预期结果）才会进结构化。
# AI_PHONE_STRUCT_STRICTNESS_HARD_SCORE=10
# AI_PHONE_STRUCT_STRICTNESS_AUDIT_SCORE=10
