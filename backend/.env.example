# ============================================================================
# ai-phone backend/.env.example
#
# 这是模板。新 Mac 上：
#   cp .env.example .env
#   再按下面注释填入本机配置（标 ★ 的字段必填）
# .env 永不进 git；.env.example 进 git，作为模板参考。
# ============================================================================


# ─────────────────── 1. 运行环境 ───────────────────

# 运行环境标识。仅用于日志区分，可留 local。可选值：local / dev / prod。
AI_PHONE_ENV=local

# 日志级别。DEBUG=最详细（排障用）/ INFO=日常 / WARNING=只看异常。
AI_PHONE_LOG_LEVEL=INFO


# ─────────────────── 2. 数据库 ★ ───────────────────

# Postgres 连接串。两种典型选择：
#   A. 共用远程 PG（找另一台 Mac 拷连接串）：
#      postgresql+asyncpg://<user>:<password>@<host>:5432/auto_app
#   B. 本机起 PG：
#      brew install postgresql@15 && brew services start postgresql@15 && createdb auto_app
#      连接串改为：postgresql+asyncpg://<本机用户>@127.0.0.1:5432/auto_app
# 注意：选 A 时同时只一台 Mac 跑 agent，否则 run id 撞车。
AI_PHONE_DB_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/auto_app

# 本地存储目录（截图、HTML 报告、调试 dump）。相对路径，相对 backend/ 工作目录。
AI_PHONE_STORAGE_DIR=./.data/storage


# ─────────────────── 3. Server（uvicorn 监听）───────────────────

# Server 监听地址；0.0.0.0=对外开放（局域网/同事远程能连）；127.0.0.1=只本机
AI_PHONE_SERVER_HOST=0.0.0.0

# Server HTTP/WS 端口
AI_PHONE_SERVER_PORT=8000

# 前端域名白名单（CORS 允许列表，**JSON 数组格式**；含 dev / 生产域名）
# 改前端部署域名时一定要同步改这里，否则浏览器报跨域
# 例：AI_PHONE_CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
AI_PHONE_CORS_ORIGINS=["http://127.0.0.1:5180","http://localhost:5180"]


# ─────────────────── 4. Agent ↔ Server 鉴权 ───────────────────

# Agent 连 Server 的 WebSocket 地址。本机 server 改成 127.0.0.1 即可。
AI_PHONE_SERVER_WS_URL=ws://127.0.0.1:8000/ws/agent

# Agent 调 Server REST API 的 base URL（截图回传、报告上传等）
AI_PHONE_SERVER_HTTP_BASE=http://127.0.0.1:8000

# Agent ↔ Server 共享 token；本地开发 dev 即可。
# 生产建议改长随机串，并保证 server 端同步更新。
AI_PHONE_AGENT_TOKEN=dev

# Agent 注册名（前端设备卡片显示在 "Agent" 字段）。留空自动用主机名。
# AI_PHONE_AGENT_NAME=mac-local

# 内部 submissions 接口 Bearer token（Web 队列总览页 / 内部投递走这把）。
# 留空则 fall back 到 AI_PHONE_AGENT_TOKEN；多人协作时建议独立设值。
# 前端通过 VITE_AI_PHONE_SUBMISSION_TOKEN 读到后带到 Authorization 头
# AI_PHONE_SUBMISSION_INTERNAL_TOKEN=


# ─────────────────── 5. VLM 主决策（视觉大模型） ★ ───────────────────

# 主 VLM 协议后端（多协议适配层）。三家自由组合，主 / 辅可以异家：
#   doubao_responses（默认）：方舟 Responses API + 显式缓存，国内推荐
#   claude_cu             ：Anthropic Messages API + computer_use_20250124 工具
#   gpt_cu                ：OpenAI Responses API + computer-use-preview 工具
# 切换协议后下面的 VLM_API_URL / VLM_API_KEY / VLM_MODEL 三个字段含义会跟随变化，
# 见每个字段下方的"换协议示例"注释。
AI_PHONE_VLM_BACKEND=doubao_responses

# 主决策端点。默认走方舟 Responses API（/responses）+ 显式缓存，长任务 prompt 前缀可复用、省 token
# 换协议示例：
#   claude_cu : https://api.anthropic.com/v1/messages
#   gpt_cu    : https://api.openai.com/v1/responses
AI_PHONE_VLM_API_URL=https://ark.cn-beijing.volces.com/api/v3/responses

# 包名匹配等单次纯文本调用走 Chat API，避免污染 Responses 的 previous_response_id
# （Claude/GPT 协议下不读这条，但留着无害）
AI_PHONE_VLM_CHAT_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 主 VLM 服务 API Key，**必填**（留空 → 401，VLM 任务跑不起来）
# 火山方舟：https://console.volcengine.com/ark
# Anthropic：https://console.anthropic.com/settings/keys
# OpenAI   ：https://platform.openai.com/api-keys
AI_PHONE_VLM_API_KEY=

# 主 VLM 模型。换模型 / 换协议时同步改这里即可。
# 换协议示例：
#   claude_cu : claude-sonnet-4-5 / claude-opus-4-1（任意支持 computer-use 的 Claude）
#   gpt_cu    : computer-use-preview
AI_PHONE_VLM_MODEL=doubao-seed-1-6-vision-250815

# 会话分段阈值：上一轮 prompt_tokens ≥ 该值时下轮自动重置 previous_response_id。
# 仅 doubao_responses / gpt_cu 这类服务端续历史协议生效；claude_cu 走客户端滑窗忽略。
# 方舟视觉 ≤32K 一档、>32K 二档 ×2 计费，30000 留 2K buffer。<=0 关闭分段。
AI_PHONE_VLM_SESSION_RESET_PROMPT_THRESHOLD=30000

# Claude 主 VLM 思考链预算（tokens）。仅 claude_cu 生效，0=关闭 thinking。
# 1024 是 Claude Computer Use 官方建议起点，足够单步决策推理。
# doubao_responses / gpt_cu 忽略本字段。
AI_PHONE_VLM_MAIN_THINKING_BUDGET=1024

# Claude / GPT 主 VLM 客户端历史滑窗保留的最近步数。
# 仅 stateless 协议（claude_cu）必须用；gpt_cu 走 previous_response_id 服务端续历史，
# doubao_responses 走显式缓存，两家都忽略本字段。
# 长任务 30 步以上时只保留首屏 1 步 + 最近 N 步对，避免 token 爆。
AI_PHONE_VLM_HISTORY_WINDOW_STEPS=12

# GPT 主 VLM 推理强度。仅 gpt_cu 生效，可选 low / medium（默认）/ high。
#   low    ：~30% 推理 token，适合 8 步内简单 case
#   medium ：平衡速度和准确度，常规自动化用
#   high   ：~3x 推理 token + 更慢，多步骤复杂决策（注意成本）
# 不可关——computer-use-preview 必须有非零 effort。
# doubao_responses / claude_cu 忽略本字段（各自走 thinking 字段控制）。
AI_PHONE_VLM_MAIN_REASONING_EFFORT=medium

# Anthropic prompt caching 开关（true / false）。仅 claude_cu 生效。默认关闭。
# 开启后 system / tools / 历史前缀会标 cache_control，Anthropic 端按 5min TTL
# 缓存复用——cache hit 后 input 单价降到 0.1x，但 cache write 单价是 1.25x，
# 所以 break-even 在 ~3 次 cache hit 之后才赚。
#   开启场景：长 case（≥20 步）+ Run 间隔短（<5 分钟），可省 60-90% input token
#   关闭场景：短 case / 调试 / Run 间隔长，cache write 成本反而亏
# doubao_responses / gpt_cu 走服务端续历史自带缓存，忽略本字段。
AI_PHONE_VLM_MAIN_PROMPT_CACHING_ENABLED=false


# ─────────────────── 6. 辅助 LLM（包名匹配 / 审判 / 断言 / 通道判定 / AI 分析） ───────────────────

# 辅助系统协议后端（与主 VLM 完全解耦，可"主 Claude + 辅 Doubao 省成本"自由组合）：
#   doubao_chat（默认）：方舟 Chat Completions
#   claude            ：Anthropic Messages API
#   openai            ：OpenAI Chat Completions
# 切换后下面的 ASSISTANT_API_URL / ASSISTANT_API_KEY / ASSISTANT_MODEL 含义跟随协议变化。
# 影响范围：包名匹配 / 通道判定 / 审判 / 断言 4 个 vlm_loop 内部调用，以及大盘"AI 分析"
# 卡片（纯文本生成 4 段总结）。这 5 处都属于"辅助/分析"类，与主 VLM 视觉决策档位独立。
AI_PHONE_ASSISTANT_BACKEND=doubao_chat

# 辅助系统模型（非视觉决策类调用）。比 vision 专版便宜快一档，避免主 VLM 自验。
# 换协议示例：
#   claude : claude-haiku-4-5 / claude-sonnet-4-5（按成本选）
#   openai : gpt-4o-mini / gpt-4.1-mini（便宜快档）
AI_PHONE_ASSISTANT_MODEL=doubao-seed-1-6-250615

# 辅助系统端点。
# 换协议示例：
#   claude : https://api.anthropic.com/v1/messages
#   openai : https://api.openai.com/v1/chat/completions
AI_PHONE_ASSISTANT_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 留空时回退到 AI_PHONE_VLM_API_KEY；主 / 辅同家时两者用同一把 key 即可。
# 主 Claude + 辅 Doubao 这种异家组合必须各自填。
AI_PHONE_ASSISTANT_API_KEY=

# 审判系统是否开混合推理（thinking）。开启后单次调用从 ~1s 涨到 ~5-15s，
# 但终局裁决准确性显著提升。审判每个 Run 只跑 1-2 次，多花几秒换准确性划算。
# 不同协议下含义：豆包=thinking.type=enabled / Claude=thinking.budget_tokens / OpenAI=reasoning.effort（仅 o-系列生效）
AI_PHONE_ASSISTANT_THINKING_JUDGE=true

# 断言系统同上（多约束验证类任务，开思考更稳）
AI_PHONE_ASSISTANT_THINKING_ASSERTION=true


# ─────────────────── 7. 瞬态 UI 检测（视频工具栏 / Toast / 半透明菜单） ───────────────────

# 总开关；开启后还需 goal 命中关键词白名单才真正启用，避免普通用例多花算力
AI_PHONE_TRANSIENT_UI_ENABLED=true

# 命中即启用瞬态 UI 检测的关键词白名单（CSV，大小写无关、忽略空格）
AI_PHONE_TRANSIENT_UI_KEYWORDS=视频,播放,倍速,直播,video,player,play,toast

# detector 抓 late 帧前的等待时间（毫秒）。需 > 工具栏典型寿命，否则 late 帧时
# 工具栏还在，三段判定的"消失率"达不到阈值。6000ms 是洋葱学园 ~5s 寿命场景的甜点
# （实测峰值比 8.71）；适配寿命更长的工具栏（8s/10s）调高即可。
AI_PHONE_TRANSIENT_UI_LATE_DELAY_MS=6000


# ─────────────────── 8. Android 镜像（scrcpy → ffmpeg → MSE） ───────────────────

# Mirror 画质 / 流量参数（agent 重启生效）
# MSE 直传方案：scrcpy → ffmpeg(-c:v copy) → 浏览器 <video>，无 JPEG 二次编码
# 三档预设：
#   省流  : MAX_WIDTH=720  BITRATE=2000000   FPS=20
#   清晰  : MAX_WIDTH=1280 BITRATE=6000000   FPS=30  ← 默认
#   锐利  : MAX_WIDTH=1920 BITRATE=12000000  FPS=30
AI_PHONE_MIRROR_MAX_WIDTH=1280
AI_PHONE_MIRROR_MAX_FPS=30
AI_PHONE_MIRROR_BITRATE=6000000

# Mirror 延迟参数（agent 重启生效，前端默认 liveSync=0.4s）
# 端到端延迟 ≈ FRAG_MS + 网络抖动 + liveSyncSeconds(前端)
#   极致低延迟：FRAG_MS=33  GOP_SEC=0    （CPU 略高，WS 帧率高）
#   平衡 (默认)：FRAG_MS=50  GOP_SEC=1
#   省 CPU/带宽：FRAG_MS=200 GOP_SEC=2
AI_PHONE_MIRROR_FRAG_MS=50
AI_PHONE_MIRROR_GOP_SEC=1


# ─────────────────── 9. iOS WDA 工程位置 + 签名信息 ★（仅 iOS 用户）───────────────────

# WebDriverAgent.xcodeproj 所在目录（**绝对路径**）。
# 项目已 vendored 在 ai-phone/third_party/WebDriverAgent，
# 改成本机 clone 仓库后的实际位置即可，例：
#   /Users/<本机用户>/code/ai-phone/third_party/WebDriverAgent
# 留空 → agent 不自动 xcodebuild test，需要你手动 Xcode Cmd+U + iproxy 起 WDA。
AI_PHONE_WDA_PROJECT_DIR=

# WDA 的 Product Bundle Identifier（xcodebuild 命令行覆盖 .pbxproj 用）。
# 两台 Mac 用不同 Apple ID 时各写各的，避免免费 Apple ID 同 Bundle Id 撞 10 个/年配额。
# 建议起 com.<本机用户名>.wda 这种唯一值。留空则用 .pbxproj 里的默认值。
AI_PHONE_WDA_BUNDLE_ID=

# Apple Developer Team ID（10 字符大写），xcodebuild 命令行覆盖 .pbxproj 里的 DEVELOPMENT_TEAM。
# 在 https://developer.apple.com/account 能查到自己的 Team ID。
# 两台 Mac 用不同 Apple ID 时各写各的。留空则用 .pbxproj 里的默认值。
AI_PHONE_WDA_TEAM_ID=


# ─────────────────── 10. iOS 镜像后端切换 ───────────────────

# iOS 镜像后端（三选一）：
#   mjpeg_passthrough（默认、推荐）：WDA mjpeg → JPEG 直通浏览器 <img>，
#                                    每帧独立，旋转/分辨率天然自适应，延迟最低
#   wda_mjpeg                    ：WDA mjpeg → ffmpeg/H.264 → MSE，
#                                    设备旋转时要重建链路；只在 passthrough 出问题时回退
#   dvt_screenshot               ：pmd3 DVT 轮询 PNG，慢、发烫，无 WDA 时保底
AI_PHONE_IOS_MIRROR_BACKEND=mjpeg_passthrough

# WDA 内部缩放到这个最长边像素（mjpeg_passthrough / wda_mjpeg 都生效；0=不缩放）
AI_PHONE_WDA_MJPEG_LONG_EDGE=1280

# JPEG 质量 10-100。passthrough 路径建议 70-80，更清晰；wda_mjpeg 路径 60 即可
AI_PHONE_WDA_MJPEG_QUALITY=80

# 目标帧率（10-30 合理）
AI_PHONE_WDA_MJPEG_FPS=20


# ─────────────────── 11. iOS WDA 生命周期 ───────────────────

# 即插即用模式：插上 iPhone 就立刻启 WDA，而不是等浏览器点"进入工作台"才启
#   false = 按需启动，省电 / 多机不争 CPU，但首次进工作台等 1~3 分钟冷编
#   true  = 插线就启，"Mac 一直烧点 CPU" 换 "点开就能用"，自动化 7x24 推荐
AI_PHONE_IOS_WDA_PRELOAD=true

# WDA 就绪后自动调 unlock + press home 唤醒屏幕（防息屏；只亮屏，不绕锁屏密码）
AI_PHONE_IOS_WAKE_ON_ENTER=true


# ─────────────────── 12. HarmonyOS 镜像后端 ───────────────────

# 鸿蒙镜像后端（agent 重启生效；不达预期改回 screenshot 立刻兜底）：
#   hypium      ：hypium Captures MJPEG socket 长连，~30fps，<100ms 延迟，
#                  折叠/异形屏天然自适应。**视频期间唯一可用**（含合成画面）
#   screenshot ：hdc shell snapshot_display 截图轮询，~8-10fps，
#                  视频期间 XComponent/SurfaceView 抓不到 → 全黑，hypium 不可用时兜底
AI_PHONE_HARMONY_MIRROR_BACKEND=hypium


# ─────────────────── 13. 大盘展示开关 + 时区 + 对外可查窗口 ───────────────────

# 大盘卡片：token 消耗统计（外部展示前期可关掉）
AI_PHONE_ANALYTICS_SHOW_TOKEN=true

# 大盘卡片：稳定性统计（外部展示前期可关掉）
AI_PHONE_ANALYTICS_SHOW_STABILITY=true

# 大盘单日切片时区（IANA 名）。海外部署改成 America/Los_Angeles 等
AI_PHONE_ANALYTICS_TIMEZONE=Asia/Shanghai

# AI 分析最多允许往前查的天数（含今天）。默认 3 = 今天/昨天/前天
AI_PHONE_ANALYTICS_AI_MAX_AGE_DAYS=3

# 对外 API 可查窗口（天）。submission 终态后 N 天内 /api/submissions/<id> 可查
# + HTML 报告可访问；超过返回 404 expired。数据/文件清理另起任务。
AI_PHONE_SUBMISSION_EXTERNAL_RETENTION_DAYS=15


# ─────────────────── 14. Midscene 执行器（外接，可选）───────────────────
# 见 `Midscene执行器接入方案.md`。寄居在 ai-phone/midscene-bridge/ 的独立 Node 工程。
# 默认关闭：开关关闭时 ai-phone 主仓零行为变化。
# Midscene 自己的配置（VLM key / 模型名等）走 midscene-bridge/.env.midscene，与本文件完全独立。

# 是否暴露 Midscene 引擎（前端下拉框 / API 校验）
AI_PHONE_MIDSCENE_ENABLED=false

# Midscene run 单次硬超时（秒）。默认 60 分钟，给长链 case 留余量
AI_PHONE_MIDSCENE_RUN_TIMEOUT_SEC=3600

# midscene-bridge 目录路径（留空 = 自动定位到 <repo>/midscene-bridge）
# AI_PHONE_MIDSCENE_BRIDGE_DIR=/Users/me/projects/ai-phone/midscene-bridge

# Node 可执行文件路径（多版本 Node 时可写绝对路径）
AI_PHONE_MIDSCENE_NODE_BIN=node


# ─────────────────── 15. Submission 终态广播（Kafka）───────────────────
# Submission 每个 item 跑到终态后，scheduler 会把结果 JSON 推到 Kafka。
# 没接 Kafka 的开发场景留 stdout 即可：终态事件就只打到日志里，不影响主流程。
#
# 详细 payload 字段见 `backend/ai_phone/server/submissions/events.py` 的 build_terminal_event。
# v1 只发终态，不广播 queued/running 中间态。

# 广播 backend 选择：
#   stdout  - 默认。终态事件以 JSON 行打到 loguru（开发 / 单机够用）
#   kafka   - 真发到下面配置的 broker（生产 / 接外部消费方）
#   null    - 关掉广播（单测 / 演示）
AI_PHONE_BROADCAST_BACKEND=stdout

# Kafka bootstrap servers，逗号分隔。留空 → KafkaPublisher 自动降级 mock（只打日志）
# 例：AI_PHONE_KAFKA_BROKERS=kafka-1.example.com:9092
# 例：AI_PHONE_KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
AI_PHONE_KAFKA_BROKERS=

# Kafka topic。v1 固定，不建议改；多环境隔离请走多 broker 或 topic 前缀
AI_PHONE_KAFKA_TOPIC=ai-phone.submission.result

# SASL/PLAIN 鉴权；公司内网明文集群可不填
# 同时填 username + password 才会启用 SASL_PLAINTEXT；否则按 PLAINTEXT 连
AI_PHONE_KAFKA_SASL_USERNAME=
AI_PHONE_KAFKA_SASL_PASSWORD=


# ============================================================================
# 高级调优（§16-§20）：默认值都是经过实测的稳定值，"误 kill 多发"等异常运维
# 场景下才需要碰；普通用户保持默认即可。每个字段的物理含义和取值范围见
# backend/ai_phone/config.py 同名字段注释。
# ============================================================================


# ─────────────────── 16. Submission 调度 TTL ───────────────────
# scheduler 兜底超时：批次 / item 跑过这个时长强制收口，防止异常 agent 永远
# 不回 RUN_DONE 把队列死锁。**这两个值开源用户几乎一定要按业务调整**：
# 短任务嫌 1h item 太长（设备 stuck 1h 才回收），长 case 嫌 3h 批次太短。

# Submission（批次）总硬超时（秒）。从 admit 时刻开始计时，超过仍未收口则
# 强制把剩余 item 标 expired 并触发终态广播。默认 3 小时（10800）。
AI_PHONE_SUBMISSION_TTL_SEC=10800

# 单个 SubmissionItem 硬超时（秒）。item 进入 running 后超时仍无 RUN_DONE
# 则强制 finalize 为 timeout。默认 1 小时（3600），覆盖典型业务 case。
AI_PHONE_ITEM_TTL_SEC=3600

# scheduler 后台 tick 周期（秒）。事件驱动路径会主动 kick，这是兜底巡检。
# 短任务高吞吐场景可调小（0.5-1s）；空闲集群可调大省 CPU。
AI_PHONE_SCHEDULER_TICK_SEC=2.0


# ─────────────────── 17. Run 行为硬上限 ───────────────────

# 单 Run 最大决策步数硬上限。超过强制 fail 收尾，防 VLM 在死路打转烧 token。
# 长链 case（>30 步）适当调大；常规短 case 100 已经偏宽松。
AI_PHONE_RUN_MAX_STEPS=100

# 单次 wait action 最大允许等待秒数（VLM 申请超过该值会被裁剪并标 clipped）。
# 默认 30 分钟（1800）为长等场景兜底；常规业务可调到 60-300s。
AI_PHONE_RUN_MAX_WAIT_SEC=1800

# 结构化通道审判（_run_struct_audit）单次调用超时（秒）。
# 超时按 ALLOW 处理不阻塞 Run；网络环境差/海外节点可调到 60-90s。
AI_PHONE_AUDIT_TIMEOUT_SEC=30

# 断言系统（finished 终局裁决）单次调用超时（秒）。
# 超时按 SKIP 处理回退主 VLM 结果，不阻塞 Run 收尾。
AI_PHONE_ASSERTION_TIMEOUT_SEC=60

# 审判系统单 Run 累计 ALLOW 次数上限。达上限后探测器召唤直接 KILL 绕过审判。
# 审判模型不稳/容易误 KILL 时调大（50-100）；想让 Run 早死省 token 调小。
# 默认 30 已经是"效果优先"取值——再嫌严格直接调大。
AI_PHONE_AUDIT_ALLOW_LIMIT=30

# 审判周期巡检间隔（步）。每 N 步主动召唤一次审判检查推进合理性。
# 0 = 关闭周期巡检（仅 detector 触发）；调大让 VLM 多跑几步再检查。
# 历史经验：5 太频繁前期合法跳步常被误 KILL，30 给足 VLM 上下文再监督。
AI_PHONE_AUDIT_PERIODIC_INTERVAL=30

# 单轮 VLM 决策最多串联多少个 Action（超出截断保留前 N 个）。
# 1 = 关闭链式（每步只走一个 Action）；视频/工具栏场景需要 ≥ 2。
AI_PHONE_CHAIN_MAX_ACTIONS=2

# 链内相邻两个 Action 的硬等间隔（毫秒）。
# 0 = 不等（极激进）；过大让链式失去毫秒级追瞬态 UI 的意义。
AI_PHONE_CHAIN_INNER_GAP_MS=200


# ─────────────────── 18. 卡死检测阈值 ───────────────────
# 这一组是本地纯算法（不调 LLM）的兜底卡死探测器。命中后会向 VLM 注入
# "卡死提示"或直接终止 Run。阈值偏小 → 误 kill 多发；偏大 → 真死循环
# 拖太久。**误 kill 多发场景，把这一组阈值整体调大 1-2 档**。

# 同坐标连续点击触发卡死提示的次数。点过 N 次同位置仍无屏变化 → 注入提示。
# 调大可减少误 kill（合法连点场景，如刷新按钮/抽奖）。
AI_PHONE_CLICK_STUCK_THRESHOLD=4

# 同方向连续无效滚动触发卡死提示的次数。N 次 swipe 屏幕几乎不动 → 注入提示。
# 长列表底部场景调大；常规列表保持默认。
AI_PHONE_SCROLL_STUCK_THRESHOLD=3

# VLM 连续输出未知 / 解析失败 action 的次数上限。超过 → 注入纠正提示。
# 模型偶尔抖动可调到 5；想严格收口调到 2。
AI_PHONE_UNKNOWN_ACTION_STREAK_LIMIT=3

# 连续截图失败次数上限。超过 → 终止 Run 标 fail（设备可能掉线/崩溃）。
# 弱网/老旧设备可调到 5-8；线上稳定环境保持默认。
AI_PHONE_CONSECUTIVE_SCREENSHOT_FAIL_LIMIT=3


# ─────────────────── 19. 异常介入触发阈值（结构化通道审判 detector）───────────────────
# 这一组是"召唤审判"的本地探测器阈值。命中后**不直接 kill**，丢给轻量审判
# 模型判定继续 / 终止。阈值偏小 → 频繁召唤审判（多 token 多延迟）；偏大 →
# 真偏离也叫不醒审判。"误 kill 多发"运维场景的关键调节区。

# 同坐标桶聚类容差（像素，质心欧氏距）。距离 ≤ 此值视为同一桶。
# 高分屏可调大（80-100）；密集 UI 调小（20-30）。
AI_PHONE_AUDIT_CLICK_BUCKET_PX=50

# 同坐标桶累计 click ≥ N 次召唤审判。
# 调大允许更多合法重试；调小快速发现反复点同一处模式。
AI_PHONE_AUDIT_CLICK_BUCKET_TRIGGER=3

# pHash 汉明距阈值，≤ 此值视为同屏。256 bit 哈希默认 8 ≈ 3% 差异。
# 调小（4-6）严格判同屏；调大（12-16）容忍更多视觉抖动。
AI_PHONE_AUDIT_SCREEN_REVISIT_HAMMING=8

# 同屏访问累计 ≥ N 次召唤审判。Tab 切换 / 抽屉开合等合法多次访问可调大。
AI_PHONE_AUDIT_SCREEN_REVISIT_TRIGGER=3

# 滚动方向翻转检测窗口（最近 N 次滚动）。
AI_PHONE_AUDIT_SCROLL_FLIP_WINDOW=6

# 窗口内方向翻转 ≥ N 次召唤审判（震荡 / 东找西找）。
AI_PHONE_AUDIT_SCROLL_FLIP_TRIGGER=2

# 滚动前后帧 diff_rate ≤ 此值视为页面几乎没动（无效滑动）。
# 调大（0.05）容忍更多视觉抖动；调小（0.005）严格判无效滑动。
AI_PHONE_AUDIT_SCROLL_NOPROGRESS_DIFF=0.02

# 同方向连续无效滑动 ≥ N 次召唤审判（已到列表底/无更多内容场景）。
AI_PHONE_AUDIT_SCROLL_NOPROGRESS_TRIGGER=3


# ─────────────────── 20. 通道判定阈值（结构化 vs 自由对话）───────────────────
# 启动期判定 case 走哪条通道：结构化（带审判 + 严格步骤校验）还是自由对话
# （VLM 自主决策）。阈值控制"严格度多高才进结构化"。
#   关键字命中 ≥ HARD_HIT       → 直接结构化（最高置信，免审判分类调用）
#   严格度评分 ≥ HARD_SCORE     → 直接结构化（长 case + 密集约束）
#   严格度评分 ≥ AUDIT_SCORE    → 借审判模型一次性分类
#   都不达标                     → 自由对话通道

# 四级标签命中数 ≥ 此值直接走结构化（免审判分类调用）。
# 标签：测试标题/前置条件/操作步骤/预期结果/起跑线/资源选择/兜底等。
AI_PHONE_STRUCT_KEYWORD_HARD_HIT=2

# 严格度综合评分 ≥ 此值直接走结构化（0-7 分制）。
# 评分维度：引号/数字约束/逻辑词/顺序词/动词等。
AI_PHONE_STRUCT_STRICTNESS_HARD_SCORE=5

# 严格度评分 ≥ 此值借审判模型分类（中等信号 case）。
# 调小让更多 case 进结构化（严格但慢）；调大放宽自由对话覆盖。
AI_PHONE_STRUCT_STRICTNESS_AUDIT_SCORE=3
