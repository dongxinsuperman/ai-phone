# ============================================================================
# ai-phone backend/.env.example
#
# 这是模板。新 Mac 上：
#   cp .env.example .env
#   再按下面注释填入本机配置（标 ★ 的字段必填）
# .env 永不进 git；.env.example 进 git，作为模板参考。
# ============================================================================


# ─────────────────── 1. 运行环境 ───────────────────

# 运行环境标识。仅用于日志区分，可留 local。可选值：local / dev / prod。
AI_PHONE_ENV=local

# 日志级别。DEBUG=最详细（排障用）/ INFO=日常 / WARNING=只看异常。
AI_PHONE_LOG_LEVEL=INFO


# ─────────────────── 2. 数据库 ★ ───────────────────

# Postgres 连接串。两种典型选择：
#   A. 共用远程 PG（找另一台 Mac 拷连接串）：
#      postgresql+asyncpg://<user>:<password>@<host>:5432/auto_app
#   B. 本机起 PG：
#      brew install postgresql@15 && brew services start postgresql@15 && createdb auto_app
#      连接串改为：postgresql+asyncpg://<本机用户>@127.0.0.1:5432/auto_app
# 注意：选 A 时同时只一台 Mac 跑 agent，否则 run id 撞车。
AI_PHONE_DB_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/auto_app

# 本地存储目录（截图、HTML 报告、调试 dump）。相对路径，相对 backend/ 工作目录。
AI_PHONE_STORAGE_DIR=./.data/storage


# ─────────────────── 3. Server（uvicorn 监听）───────────────────

# Server 监听地址；0.0.0.0=对外开放（局域网/同事远程能连）；127.0.0.1=只本机
AI_PHONE_SERVER_HOST=0.0.0.0

# Server HTTP/WS 端口
AI_PHONE_SERVER_PORT=8000


# ─────────────────── 4. Agent ↔ Server 鉴权 ───────────────────

# Agent 连 Server 的 WebSocket 地址。本机 server 改成 127.0.0.1 即可。
AI_PHONE_SERVER_WS_URL=ws://127.0.0.1:8000/ws/agent

# Agent 调 Server REST API 的 base URL（截图回传、报告上传等）
AI_PHONE_SERVER_HTTP_BASE=http://127.0.0.1:8000

# Agent ↔ Server 共享 token；本地开发 dev 即可。
# 生产建议改长随机串，并保证 server 端同步更新。
AI_PHONE_AGENT_TOKEN=dev

# Agent 注册名（前端设备卡片显示在 "Agent" 字段）。留空自动用主机名。
# AI_PHONE_AGENT_NAME=mac-local


# ─────────────────── 5. VLM 主决策（视觉大模型） ★ ───────────────────

# 主决策走 Responses API（/responses）+ 显式缓存，长任务 prompt 前缀可复用、省 token
AI_PHONE_VLM_API_URL=https://ark.cn-beijing.volces.com/api/v3/responses

# 包名匹配等单次纯文本调用走 Chat API，避免污染 Responses 的 previous_response_id
AI_PHONE_VLM_CHAT_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 火山引擎方舟 API Key，**必填**（留空 → 401，VLM 任务跑不起来）
# 申请：https://console.volcengine.com/ark
AI_PHONE_VLM_API_KEY=

# 主 VLM 模型（视觉版）。换模型在方舟控制台开通后改这里即可。
AI_PHONE_VLM_MODEL=doubao-seed-1-6-vision-250815

# 会话分段阈值：上一轮 prompt_tokens ≥ 该值时下轮自动重置 previous_response_id。
# 方舟视觉 ≤32K 一档、>32K 二档 ×2 计费，30000 留 2K buffer。<=0 关闭分段。
AI_PHONE_VLM_SESSION_RESET_PROMPT_THRESHOLD=30000


# ─────────────────── 6. 辅助 LLM（包名匹配 / 审判 / 断言 / 通道判定） ───────────────────

# 辅助系统模型（非视觉决策类调用）。比 vision 专版便宜快一档，避免主 VLM 自验。
AI_PHONE_ASSISTANT_MODEL=doubao-seed-1-6-250615
AI_PHONE_ASSISTANT_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 留空时回退到 AI_PHONE_VLM_API_KEY；多数情况两者用同一个 ark key 即可
AI_PHONE_ASSISTANT_API_KEY=

# 审判系统是否开混合推理（thinking）。开启后单次调用从 ~1s 涨到 ~5-15s，
# 但终局裁决准确性显著提升。审判每个 Run 只跑 1-2 次，多花几秒换准确性划算。
AI_PHONE_ASSISTANT_THINKING_JUDGE=true

# 断言系统同上（多约束验证类任务，开思考更稳）
AI_PHONE_ASSISTANT_THINKING_ASSERTION=true


# ─────────────────── 7. 瞬态 UI 检测（视频工具栏 / Toast / 半透明菜单） ───────────────────

# 总开关；开启后还需 goal 命中关键词白名单才真正启用，避免普通用例多花算力
AI_PHONE_TRANSIENT_UI_ENABLED=true

# 命中即启用瞬态 UI 检测的关键词白名单（CSV，大小写无关、忽略空格）
AI_PHONE_TRANSIENT_UI_KEYWORDS=视频,播放,倍速,直播,video,player,play,toast

# detector 抓 late 帧前的等待时间（毫秒）。需 > 工具栏典型寿命，否则 late 帧时
# 工具栏还在，三段判定的"消失率"达不到阈值。6000ms 是洋葱学园 ~5s 寿命场景的甜点
# （实测峰值比 8.71）；适配寿命更长的工具栏（8s/10s）调高即可。
AI_PHONE_TRANSIENT_UI_LATE_DELAY_MS=6000


# ─────────────────── 8. Android 镜像（scrcpy → ffmpeg → MSE） ───────────────────

# Mirror 画质 / 流量参数（agent 重启生效）
# MSE 直传方案：scrcpy → ffmpeg(-c:v copy) → 浏览器 <video>，无 JPEG 二次编码
# 三档预设：
#   省流  : MAX_WIDTH=720  BITRATE=2000000   FPS=20
#   清晰  : MAX_WIDTH=1280 BITRATE=6000000   FPS=30  ← 默认
#   锐利  : MAX_WIDTH=1920 BITRATE=12000000  FPS=30
AI_PHONE_MIRROR_MAX_WIDTH=1280
AI_PHONE_MIRROR_MAX_FPS=30
AI_PHONE_MIRROR_BITRATE=6000000

# Mirror 延迟参数（agent 重启生效，前端默认 liveSync=0.4s）
# 端到端延迟 ≈ FRAG_MS + 网络抖动 + liveSyncSeconds(前端)
#   极致低延迟：FRAG_MS=33  GOP_SEC=0    （CPU 略高，WS 帧率高）
#   平衡 (默认)：FRAG_MS=50  GOP_SEC=1
#   省 CPU/带宽：FRAG_MS=200 GOP_SEC=2
AI_PHONE_MIRROR_FRAG_MS=50
AI_PHONE_MIRROR_GOP_SEC=1


# ─────────────────── 9. iOS WDA 工程位置 + 签名信息 ★（仅 iOS 用户）───────────────────

# WebDriverAgent.xcodeproj 所在目录（**绝对路径**）。
# 项目已 vendored 在 ai-phone/third_party/WebDriverAgent，
# 改成本机 clone 仓库后的实际位置即可，例：
#   /Users/<本机用户>/code/ai-phone/third_party/WebDriverAgent
# 留空 → agent 不自动 xcodebuild test，需要你手动 Xcode Cmd+U + iproxy 起 WDA。
AI_PHONE_WDA_PROJECT_DIR=

# WDA 的 Product Bundle Identifier（xcodebuild 命令行覆盖 .pbxproj 用）。
# 两台 Mac 用不同 Apple ID 时各写各的，避免免费 Apple ID 同 Bundle Id 撞 10 个/年配额。
# 建议起 com.<本机用户名>.wda 这种唯一值。留空则用 .pbxproj 里的默认值。
AI_PHONE_WDA_BUNDLE_ID=

# Apple Developer Team ID（10 字符大写），xcodebuild 命令行覆盖 .pbxproj 里的 DEVELOPMENT_TEAM。
# 在 https://developer.apple.com/account 能查到自己的 Team ID。
# 两台 Mac 用不同 Apple ID 时各写各的。留空则用 .pbxproj 里的默认值。
AI_PHONE_WDA_TEAM_ID=


# ─────────────────── 10. iOS 镜像后端切换 ───────────────────

# iOS 镜像后端（三选一）：
#   mjpeg_passthrough（默认、推荐）：WDA mjpeg → JPEG 直通浏览器 <img>，
#                                    每帧独立，旋转/分辨率天然自适应，延迟最低
#   wda_mjpeg                    ：WDA mjpeg → ffmpeg/H.264 → MSE，
#                                    设备旋转时要重建链路；只在 passthrough 出问题时回退
#   dvt_screenshot               ：pmd3 DVT 轮询 PNG，慢、发烫，无 WDA 时保底
AI_PHONE_IOS_MIRROR_BACKEND=mjpeg_passthrough

# WDA 内部缩放到这个最长边像素（mjpeg_passthrough / wda_mjpeg 都生效；0=不缩放）
AI_PHONE_WDA_MJPEG_LONG_EDGE=1280

# JPEG 质量 10-100。passthrough 路径建议 70-80，更清晰；wda_mjpeg 路径 60 即可
AI_PHONE_WDA_MJPEG_QUALITY=80

# 目标帧率（10-30 合理）
AI_PHONE_WDA_MJPEG_FPS=20


# ─────────────────── 11. iOS WDA 生命周期 ───────────────────

# 即插即用模式：插上 iPhone 就立刻启 WDA，而不是等浏览器点"进入工作台"才启
#   false = 按需启动，省电 / 多机不争 CPU，但首次进工作台等 1~3 分钟冷编
#   true  = 插线就启，"Mac 一直烧点 CPU" 换 "点开就能用"，自动化 7x24 推荐
AI_PHONE_IOS_WDA_PRELOAD=true

# WDA 就绪后自动调 unlock + press home 唤醒屏幕（防息屏；只亮屏，不绕锁屏密码）
AI_PHONE_IOS_WAKE_ON_ENTER=true


# ─────────────────── 12. HarmonyOS 镜像后端 ───────────────────

# 鸿蒙镜像后端（agent 重启生效；不达预期改回 screenshot 立刻兜底）：
#   hypium      ：hypium Captures MJPEG socket 长连，~30fps，<100ms 延迟，
#                  折叠/异形屏天然自适应。**视频期间唯一可用**（含合成画面）
#   screenshot ：hdc shell snapshot_display 截图轮询，~8-10fps，
#                  视频期间 XComponent/SurfaceView 抓不到 → 全黑，hypium 不可用时兜底
AI_PHONE_HARMONY_MIRROR_BACKEND=hypium


# ─────────────────── 13. 大盘展示开关 ───────────────────

# 大盘卡片：token 消耗统计（外部展示前期可关掉）
AI_PHONE_ANALYTICS_SHOW_TOKEN=true

# 大盘卡片：稳定性统计（外部展示前期可关掉）
AI_PHONE_ANALYTICS_SHOW_STABILITY=true
